  padding: 9px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-reset:hover {
  background: #fde8c0;
}
.btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  color: #fff;
  border: none;
  padding: 10px 28px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition:
    box-shadow 0.2s,
    transform 0.2s;
}
.btn-submit:hover:not(:disabled) {
  box-shadow: 0 4px 14px rgba(124, 58, 237, 0.35);
  transform: translateY(-1px);
}
.btn-submit:disabled,
.btn-cancel:disabled,
.btn-reset:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

/* ── Auto-fill label ── */
.auto-label {
  font-size: 10px;
  font-weight: 700;
  background: #ede9fe;
  color: #7c3aed;
  padding: 2px 7px;
  border-radius: 20px;
  margin-left: 6px;
  vertical-align: middle;
}

/* ── Taxpayer Search (TIN-style) ── */
.search-row {
  display: flex;
  gap: 10px;
  align-items: center;
}
.search-input-wrap {
  flex: 1;
}
.btn-search {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: #fff;
  border: none;
  padding: 10px 22px;
  border-radius: 9px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.2s;
}
.btn-search:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Search Results */
.search-results {
  margin-top: 8px;
  border: 1.5px solid #e0e8f0;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07);
}
.result-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  cursor: pointer;
  transition: background 0.15s;
  border-bottom: 1px solid #f0f4f8;
}
.result-item:last-child { border-bottom: none; }
.result-item:hover { background: #f0f4ff; }
.result-avatar {
  width: 36px;
  height: 36px;
  background: #ede9fe;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7c3aed;
  font-size: 16px;
  flex-shrink: 0;
}
.result-info { flex: 1; }
.result-name { font-size: 13.5px; font-weight: 600; color: #1a2340; display: block; }
.result-meta { font-size: 12px; color: #888; display: block; margin-top: 2px; }
.result-badge {
  font-size: 11px;
  font-weight: 600;
  background: #ede9fe;
  color: #7c3aed;
  padding: 3px 10px;
  border-radius: 20px;
}

/* No result note */
.no-result-note {
  margin-top: 10px;
  padding: 10px 14px;
  background: #fff8e1;
  border: 1px solid #ffe082;
  border-radius: 8px;
  font-size: 12.5px;
  color: #b45309;
  display: flex;
  align-items: center;
  gap: 7px;
}

/* Selected Taxpayer Card */
.selected-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12px;
  padding: 12px 16px;
  background: #f0fdf4;
  border: 1.5px solid #86efac;
  border-radius: 10px;
}
.selected-card-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.selected-avatar {
  width: 38px;
  height: 38px;
  background: #dcfce7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #16a34a;
  font-size: 18px;
  flex-shrink: 0;
}
.selected-name {
  margin: 0;
  font-size: 13.5px;
  font-weight: 700;
  color: #14532d;
}
.selected-meta {
  margin: 2px 0 0;
  font-size: 12px;
  color: #16a34a;
}
.autofill-tag {
  font-size: 11.5px;
  font-weight: 700;
  background: #dcfce7;
  color: #16a34a;
  padding: 4px 12px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  gap: 5px;
}

/* Clear button inside input */
.clear-btn {
  position: absolute;
  right: 12px;
  background: none;
  border: none;
  color: #aaa;
  cursor: pointer;
  font-size: 13px;
  padding: 2px;
  display: flex;
  align-items: center;
}
.clear-btn:hover { color: #e74c3c; }

/* Locked auto-filled fields */
.input-wrap.locked .form-input {
  background: #f0fdf4;
  border-color: #86efac;
  color: #15803d;
}
.lock-icon {
  position: absolute;
  right: 12px;
  color: #16a34a;
  font-size: 12px;
}

@media (max-width: 768px) {
  .form-section {
    padding: 18px 16px;
  }
  .section-divider {
    margin: 0 16px;
  }
  .form-grid {
    grid-template-columns: 1fr;
  }
  .form-actions {
    padding: 16px;
    justify-content: stretch;
  }
  .btn-cancel,
  .btn-reset,
  .btn-submit {
    flex: 1;
    justify-content: center;
  }
  .search-row { flex-direction: column; }
  .btn-search { width: 100%; justify-content: center; }
  .selected-card { flex-direction: column; align-items: flex-start; gap: 8px; }
}
@media (max-width: 480px) {
  .form-actions {
    flex-direction: column;
  }
  .btn-cancel,
  .btn-reset,
  .btn-submit {
    width: 100%;
  }
}

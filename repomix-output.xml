  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}
.alert-error {
  background: #fff0f0;
  border: 1px solid #fcc;
  border-radius: 10px;
  padding: 12px 18px;
  color: #e74c3c;
  font-weight: 600;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}
.loading-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300px;
  gap: 12px;
}
.form-card {
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  overflow: hidden;
}
.edit-banner {
  background: #f3eeff;
  padding: 12px 28px;
  border-bottom: 1px solid #e0d5f5;
  font-size: 13px;
  color: #555;
  display: flex;
  align-items: center;
  gap: 8px;
}
.edit-banner i {
  color: #7c3aed;
}
.edit-banner strong {
  color: #7c3aed;
  font-family: monospace;
}
.banner-sub {
  font-size: 12px;
  color: #888;
  margin-left: 4px;
}
.form-section {
  padding: 24px 28px;
}
.section-header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}
.section-icon {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 17px;
  flex-shrink: 0;
}
.section-icon.purple {
  background: linear-gradient(135deg, #7c3aed, #a855f7);
}
.section-icon.teal {
  background: linear-gradient(135deg, #1faa8b, #17c69a);
}
.section-icon.orange {
  background: linear-gradient(135deg, #f59e0b, #f97316);
}
.section-title {
  margin: 0;
  font-size: 14px;
  font-weight: 700;
  color: #1a2340;
}
.section-sub {
  font-size: 12px;
  color: #999;
}
.section-divider {
  height: 1px;
  background: #f0f4f8;
  margin: 0 28px;
}
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.form-group.full-width {
  grid-column: 1/-1;
}
.form-label {
  font-size: 13px;
  font-weight: 600;
  color: #444;
}
.form-label.required::after {
  content: " *";
  color: #e74c3c;
}
.input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}
.input-icon {
  position: absolute;
  left: 12px;
  color: #aaa;
  font-size: 14px;
  pointer-events: none;
  z-index: 1;
}
.textarea-icon {
  top: 12px;
  align-self: flex-start;
}
.form-input {
  width: 100%;
  padding: 10px 14px 10px 36px;
  border: 1.5px solid #e0e8f0;
  border-radius: 9px;
  font-size: 13.5px;
  color: #333;
  background: #fafbfc;
  outline: none;
  transition:
    border-color 0.2s,
    box-shadow 0.2s;
  font-family: inherit;
}
.form-input:focus {
  border-color: #7c3aed;
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.08);
  background: #fff;
}
.form-select {
  appearance: none;
  cursor: pointer;
}
.form-textarea {
  resize: vertical;
  min-height: 70px;
  padding-top: 10px;
}
.calc-field {
  background: #f3eeff !important;
  color: #7c3aed !important;
  font-weight: 700;
  cursor: not-allowed;
  border-color: #e0d5f5 !important;
}

/* ── Net Display ── */
.net-display-row {
  margin-top: 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 18px;
  background: #f8f5ff;
  border: 1.5px solid #e0d5f5;
  border-radius: 12px;
}
.nd-item {
  flex: 1;
}
.nd-item.highlight {
  background: #f3eeff;
  padding: 10px 14px;
  border-radius: 8px;
}
.nd-label {
  display: block;
  font-size: 12px;
  color: #888;
  font-weight: 500;
  margin-bottom: 4px;
}
.nd-value {
  display: block;
  font-size: 18px;
  font-weight: 800;
}
.nd-value.taxable {
  color: #1a2340;
}
.nd-value.net {
  color: #7c3aed;
}
.nd-arrow {
  color: #c4b5f5;
  font-size: 20px;
}

.form-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  padding: 20px 28px;
  background: #f8fafc;
  border-top: 1px solid #f0f4f8;
  flex-wrap: wrap;
}
.btn-cancel {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fff;
  border: 1.5px solid #e0e8f0;
  color: #666;
  padding: 9px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}
.btn-cancel:hover {
  background: #f5f7fb;
}
.btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  color: #fff;
  border: none;
  padding: 10px 28px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition:
    box-shadow 0.2s,
    transform 0.2s;
}
.btn-submit:hover:not(:disabled) {
  box-shadow: 0 4px 14px rgba(124, 58, 237, 0.35);
  transform: translateY(-1px);
}
.btn-submit:disabled,
.btn-cancel:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}
@media (max-width: 768px) {
  .form-section {
    padding: 18px 16px;
  }
  .section-divider {
    margin: 0 16px;
  }
  .form-grid {
    grid-template-columns: 1fr;
  }
  .form-actions {
    padding: 16px;
    justify-content: stretch;
  }
  .btn-cancel,
  .btn-submit {
    flex: 1;
    justify-content: center;
  }
}
@media (max-width: 480px) {
  .form-actions {
    flex-direction: column;
  }
  .btn-cancel,
  .btn-submit {
    width: 100%;
  }
}
</file>


  .section-divider {
    margin: 0 16px;
  }
  .form-grid {
    grid-template-columns: 1fr;
  }
  .form-actions {
    padding: 16px;
    justify-content: stretch;
  }
  .btn-cancel,
  .btn-reset,
  .btn-submit {
    flex: 1;
    justify-content: center;
  }
}
@media (max-width: 480px) {
  .form-actions {
    flex-direction: column;
  }
  .btn-cancel,
  .btn-reset,
  .btn-submit {
    width: 100%;
  }
}


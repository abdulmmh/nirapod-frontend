<file path="src/app/features/roles/pages/roles-create/roles-create.component.css">
.btn-back { display:inline-flex; align-items:center; gap:7px; background:#fff; border:1px solid #d0daf5; color:#1a3f8f; padding:8px 16px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; }
.btn-back:hover { background:#f0f4ff; }
.alert-success { background:#e6f7f3; border:1px solid #b2dfdb; border-radius:10px; padding:12px 18px; color:#1faa8b; font-weight:600; font-size:13px; display:flex; align-items:center; gap:8px; margin-bottom:16px; }
.alert-error   { background:#fff0f0; border:1px solid #fcc; border-radius:10px; padding:12px 18px; color:#e74c3c; font-weight:600; font-size:13px; display:flex; align-items:center; gap:8px; margin-bottom:16px; }

.form-card { background:#fff; border-radius:14px; box-shadow:0 2px 16px rgba(0,0,0,0.07); overflow:hidden; }
.form-section { padding:24px 28px; }
.section-header { display:flex; align-items:center; gap:14px; margin-bottom:20px; }
.section-icon { width:40px; height:40px; background:linear-gradient(135deg,#1a3f8f,#2a5fd6); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:17px; flex-shrink:0; }
.section-icon.purple { background:linear-gradient(135deg,#7c3aed,#a855f7); }
.section-title { margin:0; font-size:14px; font-weight:700; color:#1a2340; }
.section-sub   { font-size:12px; color:#999; }
.section-divider { height:1px; background:#f0f4f8; margin:0 28px; }

.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
.form-group { display:flex; flex-direction:column; gap:6px; }
.form-group.full-width { grid-column:1/-1; }
.form-label { font-size:13px; font-weight:600; color:#444; }
.form-label.required::after { content:' *'; color:#e74c3c; }
.auto-label { font-size:10px; font-weight:600; background:#e0f2f9; color:#0891b2; padding:1px 6px; border-radius:4px; margin-left:4px; }

.input-wrap { position:relative; display:flex; align-items:center; }
.input-icon { position:absolute; left:12px; color:#aaa; font-size:14px; pointer-events:none; z-index:1; }
.textarea-icon { top:12px; align-self:flex-start; }
.form-input { width:100%; padding:10px 14px 10px 36px; border:1.5px solid #e0e8f0; border-radius:9px; font-size:13.5px; color:#333; background:#fafbfc; outline:none; transition:border-color 0.2s; font-family:inherit; }
.form-input:focus { border-color:#1a3f8f; box-shadow:0 0 0 3px rgba(26,63,143,0.08); background:#fff; }
.form-select { appearance:none; cursor:pointer; }
.form-textarea { resize:vertical; min-height:70px; padding-top:10px; }
.auto-field { background:#f0f4f8 !important; color:#555 !important; cursor:not-allowed; }

/* Color Picker */
.color-wrap { display:flex; align-items:center; gap:10px; }
.color-picker { width:44px; height:44px; border:2px solid #e0e8f0; border-radius:8px; padding:2px; cursor:pointer; background:transparent; }
.color-preview { padding:6px 14px; border-radius:8px; font-size:12px; font-weight:700; color:#fff; transition:background 0.2s; }

/* Permission Quick Actions */
.perm-quick-actions { margin-left:auto; display:flex; gap:8px; }
.pqa-btn { display:inline-flex; align-items:center; gap:5px; background:#e8eef9; color:#1a3f8f; border:none; padding:7px 14px; border-radius:7px; font-size:12px; font-weight:600; cursor:pointer; transition:background 0.2s; }
.pqa-btn:hover { background:#d0daf5; }
.pqa-btn.clear { background:#fff0f0; color:#e74c3c; }
.pqa-btn.clear:hover { background:#ffcccc; }

/* Permission Table */
.perm-table-wrap { overflow-x:auto; margin-top:4px; }
.perm-table { width:100%; border-collapse:collapse; font-size:13px; min-width:600px; }
.perm-table thead tr { background:#f8fafc; }
.perm-table th { padding:12px 16px; text-align:center; font-size:11px; font-weight:700; color:#888; text-transform:uppercase; letter-spacing:0.5px; border-bottom:2px solid #eef2f8; }
.perm-table th.module-col { text-align:left; width:35%; }
.perm-col { width:10%; }
.perm-col i { font-size:12px; margin-right:3px; }
.perm-table td { padding:10px 16px; border-bottom:1px solid #f5f7fb; text-align:center; vertical-align:middle; }
.perm-table tbody tr:last-child td { border-bottom:none; }
.perm-table tbody tr:hover { background:#f8faff; }
.perm-table tbody tr.odd-row { background:#fafbfc; }
.perm-table tbody tr.odd-row:hover { background:#f0f4ff; }
.module-name { text-align:left; font-size:13px; font-weight:600; color:#1a2340; }

/* Custom Checkbox */
.check-wrap {
  display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer; width: 24px; height: 24px; position: relative;
}
.check-wrap input { position:absolute; opacity:0; width:0; height:0; }
.checkmark {
  width: 20px; height: 20px; border-radius: 5px;
  border: 2px solid #e0e8f0; background: #fff;
  transition: all 0.15s; display: flex; align-items: center; justify-content: center;
}
.check-wrap input:checked ~ .checkmark { border-color: transparent; }
.check-wrap input:checked ~ .checkmark::after {
  content: '✓'; color: #fff; font-size: 12px; font-weight: 700;
}
.check-wrap:hover .checkmark { border-color: #1a3f8f; }

/* .checkmark.create { } */
.check-wrap input:checked ~ .checkmark.create { background: #1faa8b; }
.check-wrap input:checked ~ .checkmark.read   { background: #1a3f8f; }
.check-wrap input:checked ~ .checkmark.update { background: #f59e0b; }
.check-wrap input:checked ~ .checkmark.delete { background: #e74c3c; }
.check-wrap input:checked ~ .checkmark.export { background: #0891b2; }
.check-wrap input:checked ~ .checkmark.all    { background: #7c3aed; }

/* Form Actions */
.form-actions { display:flex; align-items:center; justify-content:flex-end; gap:10px; padding:20px 28px; background:#f8fafc; border-top:1px solid #f0f4f8; }
.btn-cancel { display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid #e0e8f0; color:#666; padding:9px 20px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; }
.btn-cancel:hover { background:#f5f7fb; }
.btn-submit { display:inline-flex; align-items:center; gap:6px; background:linear-gradient(135deg,#1a3f8f,#2a5fd6); color:#fff; border:none; padding:10px 28px; border-radius:8px; font-size:13px; font-weight:700; cursor:pointer; transition:box-shadow 0.2s,transform 0.2s; }
.btn-submit:hover:not(:disabled) { box-shadow:0 4px 14px rgba(26,63,143,0.35); transform:translateY(-1px); }
.btn-submit:disabled,.btn-cancel:disabled { opacity:0.6; cursor:not-allowed; }

@media (max-width:768px) {
  .form-section { padding:18px 16px; }
  .section-divider { margin:0 16px; }
  .form-grid { grid-template-columns:1fr; }
  .section-header { flex-wrap:wrap; }
  .perm-quick-actions { margin-left:0; }
  .form-actions { padding:16px; }
  .btn-cancel,.btn-submit { flex:1; justify-content:center; }
}

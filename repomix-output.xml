<file path="src/app/layout/topbar/topbar.component.css">
.topbar {
  height: 64px;
  background: linear-gradient(90deg, #1a9e7e 0%, #1faa8b 50%, #22bd9c 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.12);
  position: sticky;
  top: 0;
  z-index: 900;
  flex-shrink: 0;
  gap: 12px;
}

/* Left */
.topbar-left {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 0;
  flex-shrink: 0;
}

.hamburger-btn {
  background: rgba(255, 255, 255, 0.15);
  border: none;
  color: #fff;
  width: 38px;
  height: 38px;
  border-radius: 8px;
  font-size: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease;
  flex-shrink: 0;
}

.hamburger-btn:hover {
  background: rgba(255, 255, 255, 0.25);
}

.topbar-title {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.title-main {
  font-size: 14px;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 320px;
}

.title-date {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 1px;
}

/* Search */
.search-box {
  position: relative;
  display: flex;
  align-items: center;
}

.desktop-search {
  flex: 1;
  max-width: 320px;
}

.search-icon {
  position: absolute;
  left: 10px;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.7);
}

.search-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.25);
  border-radius: 20px;
  color: #fff;
  padding: 7px 14px 7px 32px;
  font-size: 13px;
  outline: none;
  transition: background 0.2s ease, border-color 0.2s ease;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.search-input:focus {
  background: rgba(255, 255, 255, 0.22);
  border-color: rgba(255, 255, 255, 0.5);
}

/* Right */
.topbar-right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

.topbar-right.hidden {
  display: none;
}

.mobile-search-toggle {
  display: none;
}

/* Buttons */
.topbar-action {
  position: relative;
}

.icon-btn {
  background: rgba(255, 255, 255, 0.15);
  border: none;
  color: #fff;
  width: 38px;
  height: 38px;
  border-radius: 8px;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease;
  position: relative;
}

.icon-btn:hover,
.icon-btn.active {
  background: rgba(255, 255, 255, 0.25);
}

.badge-dot {
  position: absolute;
  top: 5px;
  right: 5px;
  background: #e74c3c;
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1.5px solid #1faa8b;
}

.topbar-divider {
  width: 1px;
  height: 28px;
  background: rgba(255, 255, 255, 0.25);
  margin: 0 2px;
}

/* User */
.user-btn {
  background: rgba(255, 255, 255, 0.15);
  border: none;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 5px 10px 5px 5px;
  border-radius: 30px;
  cursor: pointer;
  transition: background 0.2s ease;
}

.user-btn:hover,
.user-btn.active {
  background: rgba(255, 255, 255, 0.25);
}

.user-avatar {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, #0f2d6b, #1a3f8f);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 14px;
  border: 2px solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}

.user-avatar.lg {
  width: 42px;
  height: 42px;
  font-size: 18px;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 13px;
  font-weight: 600;
  line-height: 1;
}

.user-role {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 2px;
}

.user-chevron {
  font-size: 11px;
  opacity: 0.8;
  transition: transform 0.3s ease;
}

.user-chevron.rotated {
  transform: rotate(180deg);
}

/* Mobile search */
.mobile-search-bar {
  display: none;
}

.close-search-btn {
  background: none;
  border: none;
  color: #fff;
  font-size: 16px;
  cursor: pointer;
  padding: 6px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mobile-search-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.35);
  border-radius: 20px;
  color: #fff;
  padding: 8px 16px;
  font-size: 14px;
  outline: none;
}

.mobile-search-input::placeholder {
  color: rgba(255, 255, 255, 0.65);
}

/* Dropdown */
.dropdown-panel {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  z-index: 9999;
  overflow: hidden;
  animation: dropIn 0.2s ease;
  color: #333;
  min-width: 280px;
}

@keyframes dropIn {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.dropdown-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-bottom: 1px solid #f0f0f0;
  font-weight: 700;
  font-size: 14px;
}

.user-header {
  gap: 12px;
  justify-content: flex-start;
}

.badge-count {
  background: #e74c3c;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 20px;
}

.notif-panel {
  width: 320px;
}

.notif-list {
  max-height: 280px;
  overflow-y: auto;
}

.notif-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid #f5f5f5;
  transition: background 0.15s ease;
  cursor: pointer;
}

.notif-item:hover {
  background: #f8f9fa;
}

.notif-item.unread {
  background: #f0f8ff;
}

.notif-item.unread:hover {
  background: #e8f4fd;
}

.notif-icon-wrap {
  width: 34px;
  height: 34px;
  background: linear-gradient(135deg, #1a3f8f, #1f4b99);

  color: #fff;
  font-size: 17px;
  flex-shrink: 0;
}

.section-icon.teal   { background: linear-gradient(135deg, #1faa8b, #17c69a); }
.section-icon.orange { background: linear-gradient(135deg, #f59e0b, #f97316); }

.section-title {
  margin: 0;
  font-size: 14px;
  font-weight: 700;
  color: #1a2340;
}

.section-sub {
  font-size: 12px;
  color: #999;
}

/* ── Divider ── */
.section-divider {
  height: 1px;
  background: #f0f4f8;
  margin: 0 28px;
}

/* ── Form Grid ── */
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group.full-width {
  grid-column: 1 / -1;
}

/* ── Label ── */
.form-label {
  font-size: 13px;
  font-weight: 600;
  color: #444;
}

.form-label.required::after {
  content: ' *';
  color: #e74c3c;
}

/* ── Input Wrap ── */
.input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 12px;
  color: #aaa;
  font-size: 14px;
  pointer-events: none;
  z-index: 1;
}

.textarea-icon {
  top: 12px;
  align-self: flex-start;
}

.form-input {
  width: 100%;
  padding: 10px 14px 10px 36px;
  border: 1.5px solid #e0e8f0;
  border-radius: 9px;
  font-size: 13.5px;
  color: #333;
  background: #fafbfc;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  font-family: inherit;
}

.form-input:focus {
  border-color: #1a3f8f;
  box-shadow: 0 0 0 3px rgba(26, 63, 143, 0.08);
  background: #fff;
}

.form-select {
  appearance: none;
  cursor: pointer;
}

.form-textarea {
  resize: vertical;
  min-height: 90px;
  padding-top: 10px;
}

/* ── Status Preview ── */
.status-preview {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  background: #f8fafc;
  border: 1.5px solid #e0e8f0;
  border-radius: 9px;
  min-height: 44px;
}

.status-hint {
  font-size: 12px;
  color: #888;
  font-style: italic;
}

/* ── Form Actions ── */
.form-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  padding: 20px 28px;
  background: #f8fafc;
  border-top: 1px solid #f0f4f8;
  flex-wrap: wrap;
}

.btn-cancel {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fff;
  border: 1.5px solid #e0e8f0;
  color: #666;
  padding: 9px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}

.btn-cancel:hover { background: #f5f7fb; }

.btn-reset {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fef3e2;
  border: 1.5px solid #fde8c0;
  color: #f59e0b;
  padding: 9px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}

.btn-reset:hover { background: #fde8c0; }

.btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #1a3f8f, #2a5fd6);
  color: #fff;
  border: none;
  padding: 10px 28px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: box-shadow 0.2s, transform 0.2s;
}

.btn-submit:hover:not(:disabled) {
  box-shadow: 0 4px 14px rgba(26, 63, 143, 0.35);
  transform: translateY(-1px);
}

.btn-submit:disabled,
.btn-cancel:disabled,
.btn-reset:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .form-section    { padding: 18px 16px; }
  .section-divider { margin: 0 16px; }
  .form-grid       { grid-template-columns: 1fr; }
  .form-actions    { padding: 16px; justify-content: stretch; }
  .btn-cancel, .btn-reset, .btn-submit {
    flex: 1;
    justify-content: center;
  }
}

@media (max-width: 480px) {
  .form-actions    { flex-direction: column; }
  .btn-cancel, .btn-reset, .btn-submit { width: 100%; }
}
</file>


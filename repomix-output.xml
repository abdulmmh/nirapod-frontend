<file path="src/app/features/vat-registration/pages/vat-registration-create/vat-registration-create.component.html">
<div class="page-header">
  <div class="page-header-left">
    <h4>Register for VAT</h4>
    <p>Register a new business for VAT.</p>
  </div>
  <button class="btn-back" (click)="onCancel()">
    <i class="bi bi-arrow-left"></i> Back to List
  </button>
</div>

<div class="alert-success" *ngIf="successMsg">
  <i class="bi bi-check-circle-fill"></i> {{ successMsg }}
</div>
<div class="alert-error" *ngIf="errorMsg">
  <i class="bi bi-exclamation-triangle-fill"></i> {{ errorMsg }}
</div>

<div class="form-card">

  <!-- Section 1: Business -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon">
        <i class="bi bi-building-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Business Information</h6>
        <span class="section-sub">Basic business and VAT details</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label required">TIN Number</label>
        <div class="input-wrap">
          <i class="bi bi-upc-scan input-icon"></i>
          <input type="text" class="form-input"
            placeholder="e.g. TIN-1001" [(ngModel)]="form.tinNumber" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">Business Name</label>
        <div class="input-wrap">
          <i class="bi bi-building input-icon"></i>
          <input type="text" class="form-input"
            placeholder="Enter business name" [(ngModel)]="form.businessName" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Owner Name</label>
        <div class="input-wrap">
          <i class="bi bi-person-fill input-icon"></i>
          <input type="text" class="form-input"
            placeholder="Enter owner name" [(ngModel)]="form.ownerName" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">VAT Category</label>
        <div class="input-wrap">
          <i class="bi bi-tag-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.vatCategory">
            <option value="">Select Category</option>
            <option *ngFor="let c of vatCategories" [value]="c">{{ c }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Business Type</label>
        <div class="input-wrap">
          <i class="bi bi-diagram-3-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.businessType">
            <option value="">Select Type</option>
            <option *ngFor="let t of businessTypes" [value]="t">{{ t }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Business Category</label>
        <div class="input-wrap">
          <i class="bi bi-grid-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.businessCategory">
            <option value="">Select Category</option>
            <option *ngFor="let c of businessCategories" [value]="c">{{ c }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Trade License No.</label>
        <div class="input-wrap">
          <i class="bi bi-journal-text input-icon"></i>
          <input type="text" class="form-input"
            placeholder="e.g. TL-44821" [(ngModel)]="form.tradeLicenseNo" />
        </div>
      </div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 2: VAT Authority -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon teal">
        <i class="bi bi-receipt-cutoff"></i>
      </div>
      <div>
        <h6 class="section-title">VAT Authority & Dates</h6>
        <span class="section-sub">Zone, circle and registration dates</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label required">VAT Zone</label>
        <div class="input-wrap">
          <i class="bi bi-grid-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.vatZone">
            <option value="">Select Zone</option>
            <option *ngFor="let z of vatZones" [value]="z">{{ z }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">VAT Circle</label>
        <div class="input-wrap">
          <i class="bi bi-circle-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.vatCircle">
            <option value="">Select Circle</option>
            <option *ngFor="let c of vatCircles" [value]="c">{{ c }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Registration Date</label>
        <div class="input-wrap">
          <i class="bi bi-calendar3 input-icon"></i>
          <input type="date" class="form-input" [(ngModel)]="form.registrationDate" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Effective Date</label>
        <div class="input-wrap">
          <i class="bi bi-calendar-check input-icon"></i>
          <input type="date" class="form-input" [(ngModel)]="form.effectiveDate" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Expiry Date</label>
        <div class="input-wrap">
          <i class="bi bi-calendar-x input-icon"></i>
          <input type="date" class="form-input" [(ngModel)]="form.expiryDate" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Annual Turnover (৳)</label>
        <div class="input-wrap">
          <i class="bi bi-currency-dollar input-icon"></i>
          <input type="number" class="form-input"
            placeholder="0" [(ngModel)]="form.annualTurnover" />
        </div>
      </div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 3: Contact -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon orange">
        <i class="bi bi-geo-alt-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Contact & Location</h6>
        <span class="section-sub">Contact details and address</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">Email</label>
        <div class="input-wrap">
          <i class="bi bi-envelope-fill input-icon"></i>
          <input type="email" class="form-input"
            placeholder="business@example.com" [(ngModel)]="form.email" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">Phone</label>
        <div class="input-wrap">
          <i class="bi bi-telephone-fill input-icon"></i>
          <input type="text" class="form-input"
            placeholder="01xxx-xxxxxx" [(ngModel)]="form.phone" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Division</label>
        <div class="input-wrap">
          <i class="bi bi-map-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.division"
            (ngModelChange)="onDivisionChange()">
            <option value="">Select Division</option>
            <option *ngFor="let d of divisions" [value]="d">{{ d }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">District</label>
        <div class="input-wrap">
          <i class="bi bi-geo-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.district"
            [disabled]="!form.division">
            <option value="">Select District</option>
            <option *ngFor="let d of availableDistricts" [value]="d">{{ d }}</option>
          </select>
        </div>
      </div>
      <div class="form-group full-width">
        <label class="form-label">Address</label>
        <div class="input-wrap">
          <i class="bi bi-geo-alt-fill input-icon textarea-icon"></i>
          <textarea class="form-input form-textarea"
            placeholder="Enter full address..."
            [(ngModel)]="form.address" rows="2"></textarea>
        </div>
      </div>
      <div class="form-group full-width">
        <label class="form-label">Remarks</label>
        <div class="input-wrap">
          <i class="bi bi-pencil-square input-icon textarea-icon"></i>
          <textarea class="form-input form-textarea"
            placeholder="Optional remarks..."
            [(ngModel)]="form.remarks" rows="2"></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="form-actions">
    <button class="btn-cancel" (click)="onCancel()" [disabled]="isLoading">
      <i class="bi bi-x-lg"></i> Cancel
    </button>
    <button class="btn-reset" (click)="onReset()" [disabled]="isLoading">
      <i class="bi bi-arrow-counterclockwise"></i> Reset
    </button>
    <button class="btn-submit" (click)="onSubmit()"
      [disabled]="isLoading || !isFormValid()">
      <span *ngIf="!isLoading"><i class="bi bi-receipt-cutoff"></i> Register VAT</span>
      <span *ngIf="isLoading"><span class="spinner-border spinner-border-sm me-2"></span>Registering...</span>
    </button>
  </div>

</div>
</file>


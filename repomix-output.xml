.notif-body {
  flex: 1;
  min-width: 0;
}

.notif-text {
  font-size: 13px;
  margin: 0;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
}

.notif-time {
  font-size: 11px;
  color: #999;
  margin-top: 2px;
  display: block;
}

.dropdown-menu-list {
  padding: 8px 0;
}

.dropdown-menu-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  font-size: 13.5px;
  color: #444;
  text-decoration: none;
  transition: background 0.15s ease, color 0.15s ease;
  cursor: pointer;
}

.dropdown-menu-item:hover {

    <button class="btn-submit" (click)="onSubmit()"
      [disabled]="isLoading || !isFormValid()">
      <span *ngIf="!isLoading"><i class="bi bi-check-lg"></i> Add Product</span>
      <span *ngIf="isLoading"><span class="spinner-border spinner-border-sm me-2"></span>Adding...</span>
    </button>
  </div>

</div>

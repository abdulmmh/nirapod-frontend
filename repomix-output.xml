<file path="src/app/features/taxable-products/pages/taxable-product-create/taxable-product-create.component.html">
<div class="page-header">
  <div class="page-header-left">
    <h4>Add Taxable Product</h4>
    <p>Register a new product with HS code and tax structure.</p>
  </div>
  <button class="btn-back" (click)="onCancel()">
    <i class="bi bi-arrow-left"></i> Back to List
  </button>
</div>

<div class="alert-success" *ngIf="successMsg">
  <i class="bi bi-check-circle-fill"></i> {{ successMsg }}
</div>
<div class="alert-error" *ngIf="errorMsg">
  <i class="bi bi-exclamation-triangle-fill"></i> {{ errorMsg }}
</div>

<div class="form-card">

  <!-- Section 1: Product Identity -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon">
        <i class="bi bi-box-seam-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Product Identity</h6>
        <span class="section-sub">Product name, HS code and category</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group full-width">
        <label class="form-label required">Product Name</label>
        <div class="input-wrap">
          <i class="bi bi-box-seam input-icon"></i>
          <input type="text" class="form-input"
            placeholder="e.g. Mobile Phone, Woven Fabric"
            [(ngModel)]="form.productName" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">HS Code</label>
        <div class="input-wrap">
          <i class="bi bi-upc input-icon"></i>
          <input type="text" class="form-input"
            placeholder="e.g. 8517.12.00" [(ngModel)]="form.hsCode" />
        </div>
        <span class="field-hint"><i class="bi bi-info-circle"></i> Harmonized System Code</span>
      </div>
      <div class="form-group">
        <label class="form-label required">Category</label>
        <div class="input-wrap">
          <i class="bi bi-grid-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.category">
            <option value="">Select Category</option>
            <option *ngFor="let c of categories" [value]="c">{{ c }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">Unit</label>
        <div class="input-wrap">
          <i class="bi bi-rulers input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.unit">
            <option value="">Select Unit</option>
            <option *ngFor="let u of units" [value]="u">{{ u }}</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 2: Tax Assignment -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon orange">
        <i class="bi bi-percent"></i>
      </div>
      <div>
        <h6 class="section-title">Tax Assignment</h6>
        <span class="section-sub">Select tax structure — rate auto-fills</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group full-width">
        <label class="form-label">Tax Structure</label>
        <div class="input-wrap">
          <i class="bi bi-sliders input-icon"></i>
          <select class="form-input form-select"
            [(ngModel)]="form.taxStructureId"
            (ngModelChange)="onTaxStructureChange()">
            <option [value]="0">Select Tax Structure</option>
            <option *ngFor="let ts of taxStructures" [value]="ts.id">
              {{ ts.name }}
            </option>
          </select>
        </div>
      </div>

      <!-- Auto-filled fields -->
      <div class="form-group">
        <label class="form-label">Tax Type <span class="auto-label">Auto</span></label>
        <div class="input-wrap">
          <i class="bi bi-tag-fill input-icon"></i>
          <input type="text" class="form-input auto-field"
            [value]="form.taxType || 'Auto from tax structure'"
            readonly />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Tax Rate (%) <span class="auto-label">Auto</span></label>
        <div class="input-wrap">
          <i class="bi bi-percent input-icon"></i>
          <input type="number" class="form-input auto-field"
            [value]="form.taxRate"
            readonly />
        </div>
        <span class="rate-preview-sm" *ngIf="form.taxRate > 0">
          {{ form.taxRate }}% applied to this product
        </span>
      </div>
    </div>

    <!-- Tax Info Card -->
    <div class="tax-info-card" *ngIf="form.taxStructureId > 0">
      <div class="tic-icon"><i class="bi bi-info-circle-fill"></i></div>
      <div class="tic-body">
        <div class="tic-type">{{ form.taxType }}</div>
        <div class="tic-rate">{{ form.taxRate }}% tax rate applied</div>
      </div>
      <div class="tic-rate-big">{{ form.taxRate }}%</div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 3: Description & Status -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon purple">
        <i class="bi bi-chat-text-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Description & Status</h6>
        <span class="section-sub">Product details and availability</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">Status</label>
        <div class="input-wrap">
          <i class="bi bi-toggle-on input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.status">
            <option *ngFor="let s of statuses" [value]="s">{{ s }}</option>
          </select>
        </div>
      </div>
      <div class="form-group full-width">
        <label class="form-label">Description</label>
        <div class="input-wrap">
          <i class="bi bi-text-paragraph input-icon textarea-icon"></i>
          <textarea class="form-input form-textarea"
            placeholder="Describe this product..."
            [(ngModel)]="form.description" rows="3"></textarea>
        </div>
      </div>
    </div>
  </div>

  <div class="form-actions">
    <button class="btn-cancel" (click)="onCancel()" [disabled]="isLoading">
      <i class="bi bi-x-lg"></i> Cancel

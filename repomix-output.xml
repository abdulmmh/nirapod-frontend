<file path="src/app/features/vat-registration/pages/vat-registration-list/vat-registration-list.component.css">
.bin-code { font-size:12px; font-weight:700; color:#1faa8b; background:#e6f7f3; padding:3px 8px; border-radius:5px; font-family:monospace; white-space:nowrap; }
.code-sm  { font-size:12px; font-weight:600; color:#555; background:#f5f7fb; padding:2px 7px; border-radius:4px; font-family:monospace; white-space:nowrap; }

.td-name { display:flex; align-items:center; gap:10px; }
.td-avatar.vat-avatar { width:32px; height:32px; background:linear-gradient(135deg,#1faa8b,#17c69a); color:#fff; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0; }
.mobile-avatar.vat-avatar { background:linear-gradient(135deg,#1faa8b,#17c69a); font-size:16px; }
.td-title { display:block; font-size:13px; font-weight:600; color:#1a2340; white-space:nowrap; }
.td-sub   { display:block; font-size:11px; color:#999; margin-top:1px; }

.amt-cell { font-weight:700; color:#1a2340; white-space:nowrap; }

/* Category */
.cat-badge { font-size:11px; font-weight:600; padding:3px 9px; border-radius:5px; white-space:nowrap; }
.cat-standard { background:#e6f7f3; color:#1faa8b; }
.cat-zero     { background:#e8eef9; color:#1a3f8f; }
.cat-exempt   { background:#fef3e2; color:#f59e0b; }
.cat-special  { background:#f3eeff; color:#7c3aed; }

/* Zone & Circle */
.zone-badge   { font-size:11px; font-weight:700; background:#e6f7f3; color:#1faa8b; padding:3px 8px; border-radius:5px; white-space:nowrap; }
.circle-badge { font-size:11px; font-weight:600; background:#f5f7fb; color:#555; padding:3px 8px; border-radius:5px; white-space:nowrap; }

/* Expiry */
.expiry-normal { font-size:13px; color:#444; }
.expiry-red    { font-size:12px; font-weight:700; color:#e74c3c; background:#fff0f0; padding:2px 8px; border-radius:5px; }

.action-btns { display:flex; gap:5px; flex-wrap:nowrap; }

/* Table */
.table-responsive { overflow-x:auto; -webkit-overflow-scrolling:touch; scrollbar-width:thin; scrollbar-color:#b2dfdb #f8fafc; }
.table-responsive::-webkit-scrollbar { height:6px; }
.table-responsive::-webkit-scrollbar-thumb { background:#86cfbc; border-radius:4px; }
.table-responsive::-webkit-scrollbar-thumb:hover { background:#1faa8b; }

.data-table { width:100%; min-width:1400px; border-collapse:collapse; font-size:13px; }
.data-table thead tr { background:#f8fafc; position:sticky; top:0; z-index:1; }
.data-table th { padding:11px 14px; text-align:left; font-size:11px; font-weight:700; color:#888; text-transform:uppercase; letter-spacing:0.5px; border-bottom:2px solid #eef2f8; white-space:nowrap; }
.data-table td { padding:11px 14px; border-bottom:1px solid #f5f7fb; color:#444; vertical-align:middle; white-space:nowrap; }
.data-table tbody tr:hover { background:#f0fff8; }
.data-table tbody tr:last-child td { border-bottom:none; }

.search-field-row { display:flex; align-items:center; gap:12px; }
.search-field-row .search-field { flex:1; }
.btn-export { display:inline-flex; align-items:center; gap:6px; background:#e6f7f3; color:#1faa8b; border:1px solid #b2dfdb; padding:9px 16px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap; transition:background 0.2s; flex-shrink:0; }
.btn-export:hover { background:#b2dfdb; border-color:#1faa8b; }
.loading-row { display:flex; align-items:center; gap:10px; padding:24px 20px; color:#888; font-size:13px; }

@media (max-width:480px) { .btn-export span { display:none; } .btn-export { padding:9px 12px; } }
</file>

<file path="src/app/features/vat-registration/pages/vat-registration-list/vat-registration-list.component.html">
<div class="page-header">
  <div class="page-header-left">
    <h4>VAT Registration</h4>
    <p>Manage all VAT registered businesses.</p>
  </div>
  <a *canDo="'create'" routerLink="/vat-registration/create"
     class="btn-add-primary desktop-add-btn">
    <i class="bi bi-plus-lg"></i> Register VAT
  </a>
</div>

<div class="page-wrapper">

  <div class="list-search-bar">
    <div class="search-field-row">
      <div class="search-field">
        <i class="bi bi-search"></i>
        <input type="text"
          placeholder="Search by BIN, business name, TIN, owner, category..."
          [(ngModel)]="searchTerm" />
      </div>
      <button *canDo="'export'" class="btn-export">
        <i class="bi bi-download"></i><span>Export</span>
      </button>
    </div>
  </div>

  <div class="loading-row" *ngIf="isLoading">
    <div class="spinner-border spinner-border-sm text-success"></div>
    <span>Loading VAT registrations...</span>
  </div>

  <!-- Desktop Table -->
  <div class="table-responsive desktop-table" *ngIf="!isLoading">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>BIN No</th>
          <th>Business</th>
          <th>VAT Category</th>
          <th>TIN</th>
          <th>VAT Zone</th>
          <th>VAT Circle</th>
          <th>Turnover</th>
          <th>Effective</th>
          <th>Expiry</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <tr *ngFor="let v of filtered; let i = index">
          <td>{{ i + 1 }}</td>

          <td><span class="bin-code">{{ v.binNo }}</span></td>

          <td>
            <div class="td-name">
              <div class="td-avatar vat-avatar">
                <i class="bi bi-receipt-cutoff"></i>
              </div>
              <div>
                <span class="td-title">{{ v.businessName }}</span>
                <span class="td-sub">{{ v.ownerName }}</span>
              </div>
            </div>
          </td>

          <td>
            <span class="cat-badge" [ngClass]="getCategoryClass(v.vatCategory)">
              {{ v.vatCategory }}
            </span>
          </td>

          <td><span class="code-sm">{{ v.tinNumber }}</span></td>

          <td><span class="zone-badge">{{ v.vatZone }}</span></td>
          <td><span class="circle-badge">{{ v.vatCircle }}</span></td>

          <td class="amt-cell">{{ formatCurrency(v.annualTurnover) }}</td>

          <td>{{ v.effectiveDate }}</td>

          <td>
            <span [class]="isExpired(v.expiryDate) ? 'expiry-red' : 'expiry-normal'">
              {{ v.expiryDate || '—' }}
            </span>
          </td>

          <td>
            <span class="status-badge" [ngClass]="getStatusClass(v.status)">
              {{ v.status }}
            </span>
          </td>

          <td>
            <div class="action-btns">
              <button class="btn-view" (click)="view(v.id)">
                <i class="bi bi-eye-fill"></i> View
              </button>
              <button *canDo="'edit'" class="btn-edit" (click)="edit(v.id)">
                <i class="bi bi-pencil-fill"></i> Edit
              </button>
              <button *hasRole="['SUPER_ADMIN','TAX_COMMISSIONER']"
                class="btn-delete" (click)="delete(v.id)">
                <i class="bi bi-trash-fill"></i>
              </button>
            </div>
          </td>
        </tr>

        <tr *ngIf="filtered.length === 0">
          <td colspan="12">
            <div class="empty-state">
              <i class="bi bi-receipt-cutoff"></i>
              <p>No VAT registrations found.</p>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Mobile Cards -->
  <div class="mobile-cards" style="padding:12px;" *ngIf="!isLoading">
    <div class="mobile-card" *ngFor="let v of filtered">
      <div class="mobile-card-header">
        <div class="mobile-card-title">
          <div class="mobile-avatar vat-avatar">
            <i class="bi bi-receipt-cutoff"></i>
          </div>
          <div>
            <div class="mobile-name">{{ v.businessName }}</div>
            <div class="mobile-sub">{{ v.binNo }}</div>
          </div>
        </div>
        <span class="status-badge" [ngClass]="getStatusClass(v.status)">
          {{ v.status }}
        </span>
      </div>
      <div class="mobile-card-body">
        <div class="mobile-field"><label>TIN</label><span>{{ v.tinNumber }}</span></div>
        <div class="mobile-field"><label>Category</label>
          <span class="cat-badge" [ngClass]="getCategoryClass(v.vatCategory)">{{ v.vatCategory }}</span>
        </div>
        <div class="mobile-field"><label>VAT Zone</label><span>{{ v.vatZone }}</span></div>
        <div class="mobile-field"><label>VAT Circle</label><span>{{ v.vatCircle }}</span></div>
        <div class="mobile-field"><label>Turnover</label><span>{{ formatCurrency(v.annualTurnover) }}</span></div>
        <div class="mobile-field"><label>District</label><span>{{ v.district }}</span></div>
        <div class="mobile-field"><label>Expiry</label>
          <span [class]="isExpired(v.expiryDate) ? 'expiry-red' : ''">{{ v.expiryDate || '—' }}</span>
        </div>
      </div>
      <div class="mobile-card-actions">
        <button class="btn-view" (click)="view(v.id)"><i class="bi bi-eye-fill"></i> View</button>
        <button *canDo="'edit'" class="btn-edit" (click)="edit(v.id)"><i class="bi bi-pencil-fill"></i> Edit</button>
        <button *hasRole="['SUPER_ADMIN','TAX_COMMISSIONER']" class="btn-delete" (click)="delete(v.id)"><i class="bi bi-trash-fill"></i></button>
      </div>
    </div>
    <div class="empty-state" *ngIf="filtered.length === 0">
      <i class="bi bi-receipt-cutoff"></i><p>No VAT registrations found.</p>
    </div>
  </div>

</div>

<button *canDo="'create'" class="fab-btn" routerLink="/vat-registration/create">
  <i class="bi bi-plus-lg"></i>
</button>
</file>


<file path="src/app/features/income-tax-returns/pages/income-tax-return-view/income-tax-return-view.component.html">
<div class="page-header">
  <div class="page-header-left">
    <h4>Income Tax Return Details</h4>
    <p>Full ITR with workflow actions.</p>
  </div>
  <div class="header-actions">
    <button class="btn-back" (click)="onBack()"><i class="bi bi-arrow-left"></i> Back</button>
    
    <ng-container *ngIf="itr?.status === 'Draft' || itr?.status === 'Send Back'">
      <button *canDo="'edit'" class="btn-edit-top" (click)="onEdit()">
        <i class="bi bi-pencil-fill"></i> Edit
      </button>
    </ng-container>

    <ng-container *ngIf="itr?.status === 'Rejected'">
      <button *canDo="'edit'" class="btn-amend-top" (click)="onEdit()">
        <i class="bi bi-arrow-repeat"></i> File Amendment
      </button>
    </ng-container>
  </div>
</div>


<div class="loading-overlay" *ngIf="isLoading">
  <div class="spinner-border" style="color:#7c3aed"></div>
</div>

<ng-container *ngIf="!isLoading && itr">

  <!-- Header Card -->
  <div class="itr-header-card">
    <div class="itr-header-left">
      <div class="itr-icon"><i class="bi bi-receipt-cutoff"></i></div>
      <div>
        <div class="itr-no">{{ itr.returnNo }}</div>
        <div class="itr-name">{{ itr.taxpayerName }}</div>
        <div class="itr-meta">
          <span class="cat-badge" [ngClass]="getCategoryClass(itr.itrCategory)">{{ itr.itrCategory }}</span>
          <span class="year-pill">{{ itr.assessmentYear }}</span>
          <span class="status-badge" [ngClass]="getStatusClass(itr.status)">{{ itr.status }}</span>
        </div>
      </div>
    </div>
    <div class="itr-header-right">
      <div class="itr-stat">
        <span class="its-label">Net Tax Payable</span>
        <span class="its-value">{{ fmt(itr.netTaxPayable) }}</span>
      </div>
      <div class="itr-stat" *ngIf="itr.refundable > 0">
        <span class="its-label">Refundable</span>
        <span class="its-value refund">{{ fmt(itr.refundable) }}</span>
      </div>
    </div>
  </div>

  <!-- ── WORKFLOW ACTION BAR ── -->
  <div class="workflow-bar"
    *ngIf="canSubmit() || canStartReview() || canAccept() || canReject() || canSendBack()">
    <div class="wb-title">
      <i class="bi bi-diagram-3-fill"></i> Workflow Actions
    </div>
    <div class="wb-actions">
      <button class="wf-btn submit"    *ngIf="canSubmit()"       (click)="openAction('Submit')">       <i class="bi bi-send-fill"></i> Submit Return</button>
      <button class="wf-btn review"    *ngIf="canStartReview()"  (click)="openAction('Start Review')"> <i class="bi bi-search"></i> Start Review</button>
      <button class="wf-btn sendback"  *ngIf="canSendBack()"     (click)="openAction('Send Back')">    <i class="bi bi-arrow-return-left"></i> Send Back</button>
      <button class="wf-btn accept"    *ngIf="canAccept()"       (click)="openAction('Accept')">       <i class="bi bi-check-circle-fill"></i> Accept</button>
      <button class="wf-btn reject"    *ngIf="canReject()"       (click)="openAction('Reject')">       <i class="bi bi-x-circle-fill"></i> Reject</button>
    </div>
  </div>

  <!-- Tax Summary Cards -->
  <div class="tax-summary-row">
    <div class="ts-card">
      <div class="tsc-icon gross-in"><i class="bi bi-cash-stack"></i></div>
      <div class="tsc-body"><span class="tsc-label">Gross Income</span><span class="tsc-value">{{ fmt(itr.grossIncome) }}</span></div>
    </div>
    <div class="ts-card">
      <div class="tsc-icon taxable"><i class="bi bi-calculator-fill"></i></div>
      <div class="tsc-body"><span class="tsc-label">Taxable Income</span><span class="tsc-value taxable">{{ fmt(itr.taxableIncome) }}</span></div>
    </div>
    <div class="ts-card">
      <div class="tsc-icon gross-tax"><i class="bi bi-percent"></i></div>
      <div class="tsc-body"><span class="tsc-label">Gross Tax ({{ itr.taxRate }}%)</span><span class="tsc-value gross-tax">{{ fmt(itr.grossTax) }}</span></div>
    </div>
    <div class="ts-card highlight">
      <div class="tsc-icon net"><i class="bi bi-arrow-right-circle-fill"></i></div>
      <div class="tsc-body"><span class="tsc-label">Net Payable</span><span class="tsc-value net">{{ fmt(itr.netTaxPayable) }}</span></div>
    </div>
    <div class="ts-card" *ngIf="itr.refundable > 0">
      <div class="tsc-icon refund"><i class="bi bi-arrow-return-left"></i></div>
      <div class="tsc-body"><span class="tsc-label">Refundable</span><span class="tsc-value refund">{{ fmt(itr.refundable) }}</span></div>
    </div>
  </div>

  <!-- Main Grid: Details + Timeline -->
  <div class="view-main-grid">

    <!-- Left: Details -->
    <div class="view-left">

      <div class="detail-card">
        <div class="detail-card-header"><i class="bi bi-person-badge-fill"></i><span>Taxpayer & Period</span></div>
        <div class="detail-body">
          <div class="detail-row"><span class="detail-label">Return No.</span><span class="detail-value"><span class="code-badge">{{ itr.returnNo }}</span></span></div>
          <div class="detail-row"><span class="detail-label">TIN No.</span><span class="detail-value"><span class="code-badge">{{ itr.tinNumber }}</span></span></div>
          <div class="detail-row"><span class="detail-label">Taxpayer</span><span class="detail-value fw-bold">{{ itr.taxpayerName }}</span></div>
          <div class="detail-row"><span class="detail-label">Category</span><span class="detail-value"><span class="cat-badge" [ngClass]="getCategoryClass(itr.itrCategory)">{{ itr.itrCategory }}</span></span></div>
          <div class="detail-row"><span class="detail-label">Assessment Year</span><span class="detail-value fw-bold">{{ itr.assessmentYear }}</span></div>
          <div class="detail-row"><span class="detail-label">Income Year</span><span class="detail-value">{{ itr.incomeYear }}</span></div>
        </div>
      </div>

      <div class="detail-card" style="margin-top:14px">
        <div class="detail-card-header"><i class="bi bi-calendar-check-fill"></i><span>Submission Details</span></div>
        <div class="detail-body">
          <div class="detail-row"><span class="detail-label">Due Date</span><span class="detail-value">{{ itr.dueDate }}</span></div>
          <div class="detail-row" *ngIf="itr.submissionDate"><span class="detail-label">Submitted On</span><span class="detail-value">{{ itr.submissionDate }}</span></div>
          <div class="detail-row" *ngIf="itr.submittedBy"><span class="detail-label">Submitted By</span><span class="detail-value">{{ itr.submittedBy }}</span></div>
          <div class="detail-row" *ngIf="itr.verifiedBy"><span class="detail-label">Verified By</span><span class="detail-value">{{ itr.verifiedBy }}</span></div>
          <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value"><span class="status-badge" [ngClass]="getStatusClass(itr.status)">{{ itr.status }}</span></span></div>
        </div>
      </div>

      <!-- Income & Tax Breakdown -->
      <div class="detail-card" style="margin-top:14px">
        <div class="detail-card-header"><i class="bi bi-table"></i><span>Income & Tax Breakdown</span></div>
        <div class="breakdown-grid">
          <div class="breakdown-col">
            <div class="bc-title">Income</div>
            <div class="detail-row"><span class="detail-label">Gross Income</span><span class="detail-value">{{ fmt(itr.grossIncome) }}</span></div>
            <div class="detail-row"><span class="detail-label">Less: Exempt</span><span class="detail-value exempt">{{ fmt(itr.exemptIncome) }}</span></div>
            <div class="detail-row highlight-row"><span class="detail-label fw-bold">Taxable Income</span><span class="detail-value fw-bold">{{ fmt(itr.taxableIncome) }}</span></div>
          </div>
          <div class="breakdown-col">
            <div class="bc-title">Tax</div>
            <div class="detail-row"><span class="detail-label">Tax Rate</span><span class="detail-value">{{ itr.taxRate }}%</span></div>
            <div class="detail-row"><span class="detail-label">Gross Tax</span><span class="detail-value tax-val">{{ fmt(itr.grossTax) }}</span></div>
            <div class="detail-row"><span class="detail-label">Less: Rebate</span><span class="detail-value exempt">{{ fmt(itr.taxRebate) }}</span></div>
            <div class="detail-row highlight-row"><span class="detail-label fw-bold">Net Payable</span><span class="detail-value fw-bold net-val">{{ fmt(itr.netTaxPayable) }}</span></div>
          </div>
          <div class="breakdown-col">
            <div class="bc-title">Payment</div>
            <div class="detail-row"><span class="detail-label">Advance Tax</span><span class="detail-value paid-val">{{ fmt(itr.advanceTaxPaid) }}</span></div>
            <div class="detail-row"><span class="detail-label">Withholding</span><span class="detail-value paid-val">{{ fmt(itr.withholdingTax) }}</span></div>
            <div class="detail-row"><span class="detail-label">Tax Paid</span><span class="detail-value paid-val">{{ fmt(itr.taxPaid) }}</span></div>
            <div class="detail-row highlight-row" *ngIf="itr.refundable > 0"><span class="detail-label fw-bold">Refundable</span><span class="detail-value fw-bold refund-val">{{ fmt(itr.refundable) }}</span></div>
          </div>
        </div>
      </div>

    </div>

    <!-- Right: Action History Timeline -->
    <div class="view-right">
      <div class="timeline-card">
        <div class="tc-header">
          <i class="bi bi-clock-history"></i>
          <span>Action History</span>
          <span class="tc-count">{{ itr.actionHistory?.length || 0 }} actions</span>
        </div>

        <div class="timeline" *ngIf="itr.actionHistory && itr.actionHistory.length > 0">
          <div class="tl-item"
            *ngFor="let a of itr.actionHistory; let last = last"
            [class.last]="last">
            <div class="tl-dot" [ngClass]="getActionColor(a.toStatus)">
              <i [class]="getActionIcon(a.action)"></i>
            </div>
            <div class="tl-body">
              <div class="tl-action">{{ a.action }}</div>
              <div class="tl-status">
                <span class="tl-from">{{ a.fromStatus }}</span>
                <i class="bi bi-arrow-right tl-arrow"></i>
                <span class="tl-to" [ngClass]="getStatusClass(a.toStatus)">{{ a.toStatus }}</span>
              </div>
              <div class="tl-meta">
                <span class="tl-user"><i class="bi bi-person-fill"></i> {{ a.performedBy }}</span>
                <span class="tl-role">{{ a.role }}</span>
              </div>
              <div class="tl-remarks" *ngIf="a.remarks">
                <i class="bi bi-chat-left-text-fill"></i> {{ a.remarks }}
              </div>
              <div class="tl-time">{{ a.timestamp }}</div>
            </div>
          </div>
        </div>

        <div class="no-history" *ngIf="!itr.actionHistory || itr.actionHistory.length === 0">
          <i class="bi bi-clock"></i><p>No action history yet</p>
        </div>
      </div>
    </div>

  </div>

</ng-container>

<!-- Action Modal — same as VAT Returns -->
<div class="modal-overlay" *ngIf="showActionModal" (click)="closeModal()">
  <div class="action-modal" (click)="$event.stopPropagation()">
    <div class="am-header" [ngClass]="'am-' + currentAction.toLowerCase().replace(' ','-')">
      <div class="am-icon">
        <i [class]="
          currentAction === 'Submit'       ? 'bi bi-send-fill'           :
          currentAction === 'Start Review' ? 'bi bi-search'              :
          currentAction === 'Accept'       ? 'bi bi-check-circle-fill'   :
          currentAction === 'Reject'       ? 'bi bi-x-circle-fill'       :
                                             'bi bi-arrow-return-left'
        "></i>
      </div>
      <div>
        <div class="am-title">{{ currentAction }} Return</div>
        <div class="am-sub">{{ itr?.returnNo }} — {{ itr?.taxpayerName }}</div>
      </div>
    </div>
    <div class="am-body">
      <div class="am-info">
        <div class="am-info-row">
          <span>Current Status</span>
          <span class="status-badge" [ngClass]="getStatusClass(itr?.status || '')">{{ itr?.status }}</span>
        </div>
        <div class="am-info-row">
          <span>New Status</span>
          <span class="status-badge" [ngClass]="getStatusClass(
            currentAction === 'Submit'       ? 'Submitted'    :
            currentAction === 'Start Review' ? 'Under Review' :
            currentAction === 'Accept'       ? 'Accepted'     :
            currentAction === 'Reject'       ? 'Rejected'     : 'Send Back'
          )">
            {{ currentAction === 'Submit' ? 'Submitted' : currentAction === 'Start Review' ? 'Under Review' : currentAction === 'Accept' ? 'Accepted' : currentAction === 'Reject' ? 'Rejected' : 'Send Back' }}
          </span>
        </div>
      </div>
      <div class="am-remarks-wrap">
        <label class="am-label">Remarks <span class="required-star" *ngIf="currentAction === 'Reject' || currentAction === 'Send Back'">* Required</span></label>
        <textarea class="am-remarks"
          [placeholder]="currentAction === 'Reject' ? 'Required — reason for rejection...' : currentAction === 'Send Back' ? 'Required — what needs correction...' : 'Optional remarks...'"
          [(ngModel)]="actionRemarks" rows="3">
        </textarea>
        <div class="am-error" *ngIf="actionError"><i class="bi bi-exclamation-triangle-fill"></i> {{ actionError }}</div>
      </div>
    </div>
    <div class="am-footer">
      <button class="am-btn-cancel" (click)="closeModal()" [disabled]="isActing">Cancel</button>
      <button class="am-btn-confirm" [ngClass]="'am-confirm-' + currentAction.toLowerCase().replace(' ','-')"
        (click)="confirmAction()" [disabled]="isActing">
        <span *ngIf="!isActing"><i class="bi bi-check-lg"></i> Confirm {{ currentAction }}</span>
        <span *ngIf="isActing"><span class="spinner-border spinner-border-sm me-2"></span>Processing...</span>
      </button>
    </div>
  </div>
</div>
</file>

<file path="src/app/features/tax-structure/pages/tax-structure-create/tax-structure-create.component.html">
<div class="page-header">
  <div class="page-header-left">
    <h4>Add Tax Structure</h4>
    <p>Define a new tax type, rate and applicability.</p>
  </div>
  <button class="btn-back" (click)="onCancel()">
    <i class="bi bi-arrow-left"></i> Back to List
  </button>
</div>

<div class="alert-success" *ngIf="successMsg">
  <i class="bi bi-check-circle-fill"></i> {{ successMsg }}
</div>
<div class="alert-error" *ngIf="errorMsg">
  <i class="bi bi-exclamation-triangle-fill"></i> {{ errorMsg }}
</div>

<div class="form-card">

  <!-- Section 1: Tax Identity -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon">
        <i class="bi bi-sliders"></i>
      </div>
      <div>
        <h6 class="section-title">Tax Identity</h6>
        <span class="section-sub">Tax name, type and rate</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group required">
          <label class="form-label required">Tax Code</label>
          <div class="input-wrap">
            <i class="bi bi-upc-scan input-icon"></i>
            <input type="text" class="form-input"
              placeholder="e.g. VAT-STD-001"
              [(ngModel)]="form.taxCode" />
          </div>
        </div>
      <div class="form-group required">
        <label class="form-label required">Tax Name</label>
        <div class="input-wrap">
          <i class="bi bi-tag-fill input-icon"></i>
          <input type="text" class="form-input"
            placeholder="e.g. Standard VAT, AIT on Salary"
            [(ngModel)]="form.taxName" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">Tax Type</label>
        <div class="input-wrap">
          <i class="bi bi-grid-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.taxType">
            <option value="">Select Type</option>
            <option *ngFor="let t of taxTypes" [value]="t">{{ t }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">Rate (%)</label>
        <div class="input-wrap rate-wrap">
          <i class="bi bi-percent input-icon"></i>
          <input type="number" class="form-input"
            placeholder="0" min="0" max="100" step="0.5"
            [(ngModel)]="form.rate" />
          <span class="rate-suffix">%</span>
        </div>
        <!-- Rate Preview -->
        <div class="rate-preview" *ngIf="form.rate > 0">
          <span class="rp-label">Preview:</span>
          <span class="rp-value">For ৳1,00,000 → Tax = ৳{{ (100000 * form.rate / 100) | number:'1.0-0' }}</span>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">Applicable To</label>
        <div class="input-wrap">
          <i class="bi bi-people-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.applicableTo">
            <option *ngFor="let a of applicables" [value]="a">{{ a }}</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 2: Validity -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon teal">
        <i class="bi bi-calendar-range-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Validity Period & Status</h6>
        <span class="section-sub">Effective and expiry dates</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label required">Effective Date</label>
        <div class="input-wrap">
          <i class="bi bi-calendar-check input-icon"></i>
          <input type="date" class="form-input" [(ngModel)]="form.effectiveDate" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Expiry Date <span class="optional">(optional)</span></label>
        <div class="input-wrap">
          <i class="bi bi-calendar-x input-icon"></i>
          <input type="date" class="form-input" [(ngModel)]="form.expiryDate" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Status</label>
        <div class="input-wrap">
          <i class="bi bi-toggle-on input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.status">
            <option *ngFor="let s of statuses" [value]="s">{{ s }}</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 3: Description -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon purple">
        <i class="bi bi-chat-text-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Description</h6>
        <span class="section-sub">Additional details about this tax</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group full-width">
        <label class="form-label">Description</label>
        <div class="input-wrap">
          <i class="bi bi-text-paragraph input-icon textarea-icon"></i>
          <textarea class="form-input form-textarea"
            placeholder="Describe this tax structure..."
            [(ngModel)]="form.description" rows="3"></textarea>
        </div>
      </div>
    </div>
  </div>

  <div class="form-actions">
    <button class="btn-cancel" (click)="onCancel()" [disabled]="isLoading">
      <i class="bi bi-x-lg"></i> Cancel
    </button>
    <button class="btn-reset" (click)="onReset()" [disabled]="isLoading">
      <i class="bi bi-arrow-counterclockwise"></i> Reset
    </button>
    <button class="btn-submit" (click)="onSubmit()"
      [disabled]="isLoading || !isFormValid()">
      <span *ngIf="!isLoading"><i class="bi bi-check-lg"></i> Create Tax Structure</span>
      <span *ngIf="isLoading"><span class="spinner-border spinner-border-sm me-2"></span>Creating...</span>
    </button>
  </div>

</div>
</file>

<file path="src/app/features/tax-structure/pages/tax-structure-list/tax-structure-list.component.html">
<div class="page-header">
  <div class="page-header-left">
    <h4>Tax Structure</h4>
    <p>Manage all tax types, rates and applicability rules.</p>
  </div>
  <a *canDo="'create'" routerLink="/tax-structure/create"
     class="btn-add-primary desktop-add-btn">
    <i class="bi bi-plus-lg"></i> Add Tax Structure
  </a>
</div>

<div class="page-wrapper">

  <div class="list-search-bar">
    <div class="search-field-row">
      <div class="search-field">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Search by code, name, type..."
          [(ngModel)]="searchTerm" />
      </div>
      <button *canDo="'export'" class="btn-export">
        <i class="bi bi-download"></i><span>Export</span>
      </button>
    </div>
  </div>

  <div class="loading-row" *ngIf="isLoading">
    <div class="spinner-border spinner-border-sm text-primary"></div>
    <span>Loading tax structures...</span>
  </div>

  <!-- Desktop Table -->
  <div class="table-responsive desktop-table" *ngIf="!isLoading">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Tax Code</th>
          <th>Tax Name</th>
          <th>Tax Type</th>
          <th>Rate (%)</th>
          <th>Applicable To</th>
          <th>Effective Date</th>
          <th>Expiry Date</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <tr *ngFor="let t of filtered; let i = index">
          <td>{{ i + 1 }}</td>
          <td><span class="tax-code">{{ t.taxCode }}</span></td>
          <td>
            <div class="td-name">
              <div class="td-avatar tax-avatar">
                <i class="bi bi-percent"></i>
              </div>
              <div>
                <span class="td-title">{{ t.taxName }}</span>
                <span class="td-sub">{{ t.description | slice:0:40 }}...</span>
              </div>
            </div>
          </td>
          <td><span class="type-badge" [ngClass]="getTypeClass(t.taxType)">{{ t.taxType }}</span></td>
          <td><span class="rate-badge">{{ t.rate }}%</span></td>
          <td><span class="applicable-badge">{{ t.applicableTo }}</span></td>
          <td>{{ t.effectiveDate }}</td>
          <td>
            <span [class]="isExpired(t.expiryDate) ? 'expiry-red' : 'expiry-normal'">
              {{ t.expiryDate || '—' }}
            </span>
          </td>
          <td>
            <span class="status-badge" [ngClass]="getStatusClass(t.status)">{{ t.status }}</span>
          </td>
          <td>
            <div class="action-btns">
              <button class="btn-view" (click)="view(t.id)">
                <i class="bi bi-eye-fill"></i> View
              </button>
              <button *canDo="'edit'" class="btn-edit" (click)="edit(t.id)">
                <i class="bi bi-pencil-fill"></i> Edit
              </button>
              <button *hasRole="['SUPER_ADMIN','TAX_COMMISSIONER']"
                class="btn-delete" (click)="delete(t.id)">
                <i class="bi bi-trash-fill"></i>
              </button>
            </div>
          </td>
        </tr>
        <tr *ngIf="filtered.length === 0">
          <td colspan="10">
            <div class="empty-state"><i class="bi bi-sliders"></i><p>No tax structures found.</p></div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Mobile Cards -->
  <div class="mobile-cards" style="padding:12px;" *ngIf="!isLoading">
    <div class="mobile-card" *ngFor="let t of filtered">
      <div class="mobile-card-header">
        <div class="mobile-card-title">
          <div class="mobile-avatar tax-avatar"><i class="bi bi-percent"></i></div>
          <div>
            <div class="mobile-name">{{ t.taxName }}</div>
            <div class="mobile-sub">{{ t.taxCode }}</div>
          </div>
        </div>
        <span class="status-badge" [ngClass]="getStatusClass(t.status)">{{ t.status }}</span>
      </div>
      <div class="mobile-card-body">
        <div class="mobile-field"><label>Type</label>
          <span class="type-badge" [ngClass]="getTypeClass(t.taxType)">{{ t.taxType }}</span>
        </div>
        <div class="mobile-field"><label>Rate</label><span class="rate-badge">{{ t.rate }}%</span></div>
        <div class="mobile-field"><label>Applicable To</label><span>{{ t.applicableTo }}</span></div>
        <div class="mobile-field"><label>Effective</label><span>{{ t.effectiveDate }}</span></div>
        <div class="mobile-field" *ngIf="t.expiryDate"><label>Expiry</label>
          <span [class]="isExpired(t.expiryDate) ? 'expiry-red' : ''">{{ t.expiryDate }}</span>
        </div>
      </div>
      <div class="mobile-card-actions">
        <button *hasRole="['SUPER_ADMIN','TAX_COMMISSIONER']"
          class="btn-delete" (click)="delete(t.id)">
          <i class="bi bi-trash-fill"></i> Delete
        </button>
      </div>
    </div>
    <div class="empty-state" *ngIf="filtered.length === 0">
      <i class="bi bi-sliders"></i><p>No tax structures found.</p>
    </div>
  </div>

</div>

<button *canDo="'create'" class="fab-btn" routerLink="/tax-structure/create">
  <i class="bi bi-plus-lg"></i>
</button>

<file path="src/app/features/tax-structure/pages/tax-structure-edit/tax-structure-edit.component.css">
.btn-back { display:inline-flex; align-items:center; gap:7px; background:#fff; border:1px solid #fde8c0; color:#f59e0b; padding:8px 16px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; }
.btn-back:hover { background:#fef3e2; }
.alert-success { background:#e6f7f3; border:1px solid #b2dfdb; border-radius:10px; padding:12px 18px; color:#1faa8b; font-weight:600; font-size:13px; display:flex; align-items:center; gap:8px; margin-bottom:16px; }
.alert-error   { background:#fff0f0; border:1px solid #fcc; border-radius:10px; padding:12px 18px; color:#e74c3c; font-weight:600; font-size:13px; display:flex; align-items:center; gap:8px; margin-bottom:16px; }
.loading-overlay { display:flex; justify-content:center; align-items:center; min-height:300px; }
.form-card { background:#fff; border-radius:14px; box-shadow:0 2px 16px rgba(0,0,0,0.07); overflow:hidden; }
.edit-banner { background:#fef3e2; padding:12px 28px; border-bottom:1px solid #fde8c0; font-size:13px; color:#555; display:flex; align-items:center; gap:8px; }
.edit-banner i { color:#f59e0b; }
.edit-banner strong { color:#f59e0b; }
.banner-code { font-family:monospace; font-size:12px; color:#888; margin-left:4px; }
.form-section { padding:24px 28px; }
.section-header { display:flex; align-items:center; gap:14px; margin-bottom:20px; }
.section-icon { width:40px; height:40px; background:linear-gradient(135deg,#f59e0b,#f97316); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:17px; flex-shrink:0; }
.section-icon.teal   { background:linear-gradient(135deg,#1faa8b,#17c69a); }
.section-icon.purple { background:linear-gradient(135deg,#7c3aed,#a855f7); }
.section-title { margin:0; font-size:14px; font-weight:700; color:#1a2340; }
.section-sub   { font-size:12px; color:#999; }
.section-divider { height:1px; background:#f0f4f8; margin:0 28px; }
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
.form-group { display:flex; flex-direction:column; gap:6px; }
.form-group.full-width { grid-column:1/-1; }
.form-label { font-size:13px; font-weight:600; color:#444; }
.form-label.required::after { content:' *'; color:#e74c3c; }
.input-wrap { position:relative; display:flex; align-items:center; }
.input-icon { position:absolute; left:12px; color:#aaa; font-size:14px; pointer-events:none; z-index:1; }
.textarea-icon { top:12px; align-self:flex-start; }
.form-input { width:100%; padding:10px 14px 10px 36px; border:1.5px solid #e0e8f0; border-radius:9px; font-size:13.5px; color:#333; background:#fafbfc; outline:none; transition:border-color 0.2s,box-shadow 0.2s; font-family:inherit; }
.form-input:focus { border-color:#f59e0b; box-shadow:0 0 0 3px rgba(245,158,11,0.08); background:#fff; }
.form-select { appearance:none; cursor:pointer; }
.form-textarea { resize:vertical; min-height:90px; padding-top:10px; }
.rate-wrap { position:relative; }
.rate-suffix { position:absolute; right:14px; font-size:15px; font-weight:800; color:#f59e0b; pointer-events:none; }
.rate-preview { margin-top:5px; font-size:12px; color:#f59e0b; font-weight:600; background:#fef3e2; padding:5px 10px; border-radius:6px; }
.form-actions { display:flex; align-items:center; justify-content:flex-end; gap:10px; padding:20px 28px; background:#f8fafc; border-top:1px solid #f0f4f8; }
.btn-cancel { display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid #e0e8f0; color:#666; padding:9px 20px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; }
.btn-submit { display:inline-flex; align-items:center; gap:6px; background:linear-gradient(135deg,#f59e0b,#f97316); color:#fff; border:none; padding:10px 28px; border-radius:8px; font-size:13px; font-weight:700; cursor:pointer; transition:box-shadow 0.2s,transform 0.2s; }
.btn-submit:hover:not(:disabled) { box-shadow:0 4px 14px rgba(245,158,11,0.35); transform:translateY(-1px); }
.btn-submit:disabled,.btn-cancel:disabled { opacity:0.6; cursor:not-allowed; }
@media (max-width:768px) { .form-section { padding:18px 16px; } .section-divider { margin:0 16px; } .form-grid { grid-template-columns:1fr; } .form-actions { padding:16px; } .btn-cancel,.btn-submit { flex:1; justify-content:center; } }

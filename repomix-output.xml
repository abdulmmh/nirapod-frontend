.btn-cancel { display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid #e0e8f0; color:#666; padding:9px 20px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; }
.btn-cancel:hover { background:#f5f7fb; }
.btn-reset { display:inline-flex; align-items:center; gap:6px; background:#fef3e2; border:1.5px solid #fde8c0; color:#f59e0b; padding:9px 20px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; }
.btn-reset:hover { background:#fde8c0; }
.btn-submit { display:inline-flex; align-items:center; gap:6px; background:linear-gradient(135deg,#1a3f8f,#2a5fd6); color:#fff; border:none; padding:10px 28px; border-radius:8px; font-size:13px; font-weight:700; cursor:pointer; transition:box-shadow 0.2s,transform 0.2s; }
.btn-submit:hover:not(:disabled) { box-shadow:0 4px 14px rgba(26,63,143,0.35); transform:translateY(-1px); }
.btn-submit:disabled,.btn-cancel:disabled,.btn-reset:disabled { opacity:0.6; cursor:not-allowed; transform:none; }
@media (max-width:768px) { .form-section { padding:18px 16px; } .section-divider { margin:0 16px; } .form-grid { grid-template-columns:1fr; } .form-actions { padding:16px; justify-content:stretch; } .btn-cancel,.btn-reset,.btn-submit { flex:1; justify-content:center; } }
@media (max-width:480px) { .form-actions { flex-direction:column; } .btn-cancel,.btn-reset,.btn-submit { width:100%; } }
</file>

<file path="src/app/features/vat-returns/pages/vat-return-create/vat-return-create.component.html">
<div class="page-header">
  <div class="page-header-left">
    <h4>File VAT Return</h4>
    <p>Submit a new VAT return for a business.</p>
  </div>
  <button class="btn-back" (click)="onCancel()">
    <i class="bi bi-arrow-left"></i> Back to List
  </button>
</div>

<div class="alert-success" *ngIf="successMsg">
  <i class="bi bi-check-circle-fill"></i> {{ successMsg }}
</div>
<div class="alert-error" *ngIf="errorMsg">
  <i class="bi bi-exclamation-triangle-fill"></i> {{ errorMsg }}
</div>

<div class="form-card">

  <!-- Section 1: Business -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon">
        <i class="bi bi-building-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Business Information</h6>
        <span class="section-sub">BIN, TIN and business details</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label required">BIN No.</label>
        <div class="input-wrap">
          <i class="bi bi-hash input-icon"></i>
          <input type="text" class="form-input"
            placeholder="e.g. BIN-2024-001001" [(ngModel)]="form.binNo" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">TIN Number</label>
        <div class="input-wrap">
          <i class="bi bi-upc-scan input-icon"></i>
          <input type="text" class="form-input"
            placeholder="e.g. TIN-1001" [(ngModel)]="form.tinNumber" />
        </div>
      </div>
      <div class="form-group full-width">
        <label class="form-label required">Business Name</label>
        <div class="input-wrap">
          <i class="bi bi-building input-icon"></i>
          <input type="text" class="form-input"
            placeholder="Enter business name" [(ngModel)]="form.businessName" />
        </div>
      </div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 2: Return Period -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon teal">
        <i class="bi bi-calendar-range-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Return Period</h6>
        <span class="section-sub">Filing period and assessment year</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label required">Return Period</label>
        <div class="input-wrap">
          <i class="bi bi-calendar3 input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.returnPeriod">
            <option *ngFor="let p of returnPeriods" [value]="p">{{ p }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">Period</label>
        <div class="input-wrap">
          <i class="bi bi-calendar-month input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.periodMonth">
            <option value="">Select Period</option>
            <option *ngFor="let m of periodOptions" [value]="m">{{ m }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label required">Year</label>
        <div class="input-wrap">
          <i class="bi bi-calendar input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.periodYear">
            <option *ngFor="let y of years" [value]="y">{{ y }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Assessment Year</label>
        <div class="input-wrap">
          <i class="bi bi-calendar-check input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.assessmentYear">
            <option *ngFor="let y of assessmentYears" [value]="y">{{ y }}</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Submission Date</label>
        <div class="input-wrap">
          <i class="bi bi-calendar3 input-icon"></i>
          <input type="date" class="form-input" [(ngModel)]="form.submissionDate" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Due Date</label>
        <div class="input-wrap">
          <i class="bi bi-calendar-x input-icon"></i>
          <input type="date" class="form-input" [(ngModel)]="form.dueDate" />
        </div>
      </div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 3: Supplies -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon purple">
        <i class="bi bi-table"></i>
      </div>
      <div>
        <h6 class="section-title">Supplies & Tax Calculation</h6>
        <span class="section-sub">Supply values and VAT computation</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">Taxable Supplies (৳)</label>
        <div class="input-wrap">
          <i class="bi bi-currency-dollar input-icon"></i>
          <input type="number" class="form-input" placeholder="0"
            [(ngModel)]="form.taxableSupplies"
            (ngModelChange)="autoCalcOutputTax()" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Exempt Supplies (৳)</label>
        <div class="input-wrap">
          <i class="bi bi-currency-dollar input-icon"></i>
          <input type="number" class="form-input" placeholder="0"
            [(ngModel)]="form.exemptSupplies" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Zero Rated Supplies (৳)</label>
        <div class="input-wrap">
          <i class="bi bi-currency-dollar input-icon"></i>
          <input type="number" class="form-input" placeholder="0"
            [(ngModel)]="form.zeroRatedSupplies" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Output VAT @ 15% (৳)</label>
        <div class="input-wrap">
          <i class="bi bi-percent input-icon"></i>
          <input type="number" class="form-input" placeholder="0"
            [(ngModel)]="form.outputTax" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Input VAT Credit (৳)</label>
        <div class="input-wrap">
          <i class="bi bi-arrow-down-circle input-icon"></i>
          <input type="number" class="form-input" placeholder="0"
            [(ngModel)]="form.inputTax" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Tax Paid (৳)</label>
        <div class="input-wrap">
          <i class="bi bi-cash-coin input-icon"></i>
          <input type="number" class="form-input" placeholder="0"
            [(ngModel)]="form.taxPaid" />
        </div>
      </div>
    </div>

    <!-- Tax Summary -->
    <div class="tax-summary">
      <div class="ts-row">
        <span class="ts-label">Total Supplies</span>
        <span class="ts-value">৳{{ totalSupplies.toLocaleString() }}</span>
      </div>
      <div class="ts-row">
        <span class="ts-label">Output Tax</span>
        <span class="ts-value output">৳{{ form.outputTax.toLocaleString() }}</span>
      </div>
      <div class="ts-row">
        <span class="ts-label">Input Tax Credit</span>
        <span class="ts-value input">— ৳{{ form.inputTax.toLocaleString() }}</span>
      </div>
      <div class="ts-divider"></div>
      <div class="ts-row total-row">
        <span class="ts-label total">Net Tax Payable</span>
        <span class="ts-value total">৳{{ netTaxPayable.toLocaleString() }}</span>
      </div>
    </div>
  </div>

  <div class="section-divider"></div>

  <!-- Section 4: Submission -->
  <div class="form-section">
    <div class="section-header">
      <div class="section-icon orange">
        <i class="bi bi-person-badge-fill"></i>
      </div>
      <div>
        <h6 class="section-title">Submission Details</h6>
        <span class="section-sub">Who is filing this return</span>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">Submitted By</label>
        <div class="input-wrap">
          <i class="bi bi-person-fill input-icon"></i>
          <select class="form-input form-select" [(ngModel)]="form.submittedBy">
            <option value="">Select</option>
            <option *ngFor="let s of submitters" [value]="s">{{ s }}</option>
          </select>
        </div>
      </div>
      <div class="form-group full-width">
        <label class="form-label">Remarks</label>
        <div class="input-wrap">
          <i class="bi bi-pencil-square input-icon textarea-icon"></i>
          <textarea class="form-input form-textarea"
            placeholder="Optional remarks..."
            [(ngModel)]="form.remarks" rows="2"></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="form-actions">
    <button class="btn-cancel" (click)="onCancel()" [disabled]="isLoading">
      <i class="bi bi-x-lg"></i> Cancel
    </button>
    <button class="btn-reset" (click)="onReset()" [disabled]="isLoading">
      <i class="bi bi-arrow-counterclockwise"></i> Reset
    </button>
    <button class="btn-submit" (click)="onSubmit()"
      [disabled]="isLoading || !isFormValid()">
      <span *ngIf="!isLoading"><i class="bi bi-send-fill"></i> File Return</span>
      <span *ngIf="isLoading"><span class="spinner-border spinner-border-sm me-2"></span>Filing...</span>
    </button>
  </div>

</div>
</file>

<file path="src/app/layout/sidebar/sidebar.component.html">
<div class="sidebar" [class.collapsed]="isCollapsed">

  <!-- Logo -->
  <div class="sidebar-logo">
    <div class="logo-icon">
      <i class="bi bi-bank2"></i>
    </div>

    <div class="logo-text" *ngIf="!isCollapsed">
      <span class="logo-title">VAT & TAX</span>
      <span class="logo-sub">Management System</span>
    </div>
  </div>

  <!-- Scrollable Nav -->
  <div class="sidebar-scroll">
    <nav class="sidebar-nav">
      <ng-container *ngFor="let item of visibleMenuItems">

        <!-- GROUP HEADER -->
        <div class="nav-group-header" *ngIf="item.isGroupHeader && !isCollapsed">
          {{ item.label }}
        </div>

        <div class="nav-group-divider" *ngIf="item.isGroupHeader && isCollapsed"></div>

        <!-- DIRECT LINK (expanded mode) -->
        <a
          *ngIf="!item.isGroupHeader && !item.children && !isCollapsed"
          class="nav-item"
          [class.active]="isActive(item.route)"
          (click)="navigate(item.route!)"
        >
          <i [class]="item.icon + ' nav-icon'"></i>
          <span class="nav-label">{{ item.label }}</span>
        </a>

        <!-- PARENT WITH CHILDREN (expanded mode) -->
        <div
          *ngIf="!item.isGroupHeader && item.children && !isCollapsed"
          class="nav-parent-wrap"
        >
          <div
            class="nav-item nav-parent"
            [class.active-parent]="isParentActive(item)"
            [class.expanded]="isExpanded(item.label)"
            (click)="toggleExpand(item.label)"
          >
            <i [class]="item.icon + ' nav-icon'"></i>
            <span class="nav-label">{{ item.label }}</span>
            <i
              class="bi bi-chevron-down nav-arrow"
              [class.rotated]="isExpanded(item.label)"
            ></i>
          </div>

          <div class="nav-children" [class.open]="isExpanded(item.label)">
            <a
              *ngFor="let child of item.children"
              class="nav-child"
              [class.active]="isActive(child.route)"
              (click)="navigate(child.route!, $event)"
            >
              <i *ngIf="child.icon" [class]="child.icon + ' child-icon'"></i>
              <span>{{ child.label }}</span>
            </a>
          </div>
        </div>

        <!-- DIRECT LINK (collapsed mode) -->
        <div
          *ngIf="!item.isGroupHeader && (!item.children || item.children.length === 0) && isCollapsed"
          class="nav-flyout-wrap"
        >
          <div
            class="nav-item collapsed-item"
            [class.active]="isActive(item.route)"
            (click)="navigate(item.route!)"
            [title]="item.label"
          >
            <i [class]="item.icon + ' nav-icon'"></i>
          </div>
        </div>

        <!-- PARENT WITH CHILDREN (collapsed mode) -->
        <div
          *ngIf="!item.isGroupHeader && item.children && item.children.length > 0 && isCollapsed"
          class="collapsed-parent-block"
        >
          <div
            class="nav-item collapsed-item"
            [class.active-parent]="isParentActive(item)"
            [title]="item.label"
            (click)="toggleExpand(item.label)"
          >
            <i [class]="item.icon + ' nav-icon'"></i>
          </div>

          <div class="collapsed-children" [class.open]="isExpanded(item.label)">
            <a
              *ngFor="let child of item.children"
              class="collapsed-child-item"
              [class.active]="isActive(child.route)"
              (click)="navigate(child.route!, $event)"
              [title]="child.label"
            >
              <i *ngIf="child.icon" [class]="child.icon + ' collapsed-child-icon'"></i>
            </a>
          </div>
        </div>

      </ng-container>
    </nav>
  </div>

  <!-- Footer -->
  <div class="sidebar-footer" *ngIf="!isCollapsed">
    <div class="sf-secure">
      <i class="bi bi-shield-lock-fill"></i>
      <span>Secure Government Portal</span>
    </div>
    <div class="sf-version">v2.0.0 • FY 2025–26</div>
  </div>

</div>
</file>


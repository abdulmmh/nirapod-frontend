/* ── Page Header ── */
.unread-badge {
  display: inline-flex; align-items: center;
  background: #e74c3c; color: #fff;
  font-size: 11px; font-weight: 700;
  padding: 2px 10px; border-radius: 12px;
  margin-left: 10px; vertical-align: middle;
}

/* ── Filter Tabs ── */
.filter-tabs {
  display: flex; align-items: center;
  gap: 6px; padding: 16px 20px;
  border-bottom: 1px solid #f0f4f8;
  flex-wrap: wrap;
}

.filter-tab {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 6px 16px; border-radius: 20px;
  font-size: 13px; font-weight: 600;
  border: 1.5px solid #e0e8f0;
  background: #fff; color: #666;
  cursor: pointer; transition: all 0.2s;
}

.filter-tab:hover { border-color: #1a3f8f; color: #1a3f8f; }

.filter-tab.active {
  background: #1a3f8f; color: #fff;
  border-color: #1a3f8f;
}

.tab-count {
  background: #e74c3c; color: #fff;
  font-size: 10px; font-weight: 700;
  padding: 1px 6px; border-radius: 10px;
}

/* ── Search ── */
.search-field-row { display: flex; align-items: center; gap: 12px; }
.search-field-row .search-field { flex: 1; }

.btn-export {
  display: inline-flex; align-items: center; gap: 6px;
  background: #e8eef9; color: #1a3f8f;
  border: 1px solid #d0daf5; padding: 9px 16px;
  border-radius: 8px; font-size: 13px; font-weight: 600;
  cursor: pointer; white-space: nowrap;
  transition: background 0.2s; flex-shrink: 0;
}
.btn-export:hover { background: #d0daf5; }

.loading-row { display: flex; align-items: center; gap: 10px; padding: 24px 20px; color: #888; font-size: 13px; }

/* ── Notice List ── */
.notice-list { padding: 12px 16px; display: flex; flex-direction: column; gap: 10px; }

/* ── Notice Card ── */
.notice-card {
  display: flex; align-items: flex-start; gap: 14px;
  background: #fff; border: 1.5px solid #f0f4f8;
  border-radius: 12px; padding: 16px 18px;
  cursor: pointer; transition: box-shadow 0.2s, border-color 0.2s;
  position: relative; overflow: hidden;
}

.notice-card:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.09);
  border-color: #d0daf5;
}

.notice-card.unread {
  background: #f8faff;
  border-color: #c5d4ef;
  border-left: 4px solid #1a3f8f;
}

/* ── Notice Icon ── */
.notice-icon {
  width: 44px; height: 44px; border-radius: 11px;
  display: flex; align-items: center;
  justify-content: center; font-size: 20px; flex-shrink: 0;
}

.type-general    { background: #e8eef9; color: #1a3f8f; }
.type-taxdue     { background: #fef3e2; color: #f59e0b; }
.type-audit      { background: #e8eef9; color: #1a3f8f; }
.type-penalty    { background: #fff0f0; color: #e74c3c; }
.type-compliance { background: #e6f7f3; color: #1faa8b; }
.type-refund     { background: #e0f2f9; color: #0891b2; }
.type-system     { background: #f0f4f8; color: #666; }
.type-reminder   { background: #fef3e2; color: #f59e0b; }

/* ── Notice Content ── */
.notice-content { flex: 1; min-width: 0; }

.notice-header-row {
  display: flex; align-items: flex-start;
  justify-content: space-between; gap: 12px;
  margin-bottom: 8px; flex-wrap: wrap;
}

.notice-title-group {
  display: flex; flex-direction: column; gap: 3px; min-width: 0;
}

.notice-no {
  font-size: 11px; font-weight: 700;
  color: #1a3f8f; font-family: monospace;
}

.notice-subject {
  font-size: 14px; color: #1a2340;
  line-height: 1.4;
}

.notice-subject.fw-bold { font-weight: 700; }

.notice-badges { display: flex; align-items: center; gap: 6px; flex-shrink: 0; flex-wrap: wrap; }

/* ── Priority Badges ── */
.pri-badge { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; }
.pri-low    { background: #f0f4f8; color: #888; }
.pri-normal { background: #e8eef9; color: #1a3f8f; }
.pri-high   { background: #fef3e2; color: #f59e0b; }
.pri-urgent { background: #fff0f0; color: #e74c3c; animation: pulse 1.5s infinite; }

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

/* ── Status Badges ── */
.status-unread { background: #1a3f8f; color: #fff; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; display: inline-block; }
.status-read   { background: #f0f4f8; color: #888; font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 10px; display: inline-block; }

/* ── Notice Body ── */
.notice-body {
  font-size: 13px; color: #666; line-height: 1.6;
  margin: 0 0 10px; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Footer Row ── */
.notice-footer-row {
  display: flex; align-items: center;
  justify-content: space-between; gap: 12px; flex-wrap: wrap;
}

.notice-meta { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }

.meta-item {
  display: flex; align-items: center; gap: 4px;
  font-size: 11px; color: #999; font-weight: 500;
}

.meta-item i { font-size: 11px; color: #1a3f8f; }
.meta-item.target i { color: #1faa8b; }

/* ── Notice Actions ── */
.notice-actions { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }

.btn-view-sm {
  display: inline-flex; align-items: center; gap: 5px;
  background: #e8eef9; color: #1a3f8f;
  border: none; padding: 5px 12px;
  border-radius: 7px; font-size: 12px; font-weight: 600;
  cursor: pointer; transition: background 0.2s;
}
.btn-view-sm:hover { background: #d0daf5; }

.btn-delete-sm {
  display: inline-flex; align-items: center;
  background: #fff0f0; color: #e74c3c;
  border: none; padding: 5px 10px;
  border-radius: 7px; font-size: 13px;
  cursor: pointer; transition: background 0.2s;
}
.btn-delete-sm:hover { background: #fdd0d0; }

/* ── Unread Dot ── */
.unread-dot {
  position: absolute; top: 16px; right: 16px;
  width: 10px; height: 10px;
  background: #e74c3c; border-radius: 50%;
  animation: blink 1.5s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

@media (max-width: 768px) {
  .notice-header-row { flex-direction: column; }
  .notice-footer-row { flex-direction: column; align-items: flex-start; }
  .filter-tabs { padding: 12px; }
  .btn-export span { display: none; }
  .btn-export { padding: 9px 12px; }
}

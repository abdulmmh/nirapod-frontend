<file path="src/app/layout/breadcrumbs/breadcrumbs.component.css">
.breadcrumb-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  background: #eaf0fb;
  border-bottom: 1px solid #d4e0f5;
  flex-shrink: 0;
}

/* ── Left Block ── */
.breadcrumb-left {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.page-title-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.page-icon {
  width: 30px;
  height: 30px;
  background: linear-gradient(135deg, #1a3f8f, #1f4b99);
  border-radius: 7px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 13px;
  flex-shrink: 0;
}

.page-title {
  margin: 0;
  font-size: 15px;
  font-weight: 700;
  color: #1a3f8f;
  line-height: 1;
}

/* ── Pills Row ── */
.breadcrumb-pills {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
}

.crumb-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 3px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
  background: #fff;
  color: #1a3f8f;
  border: 1px solid #c5d4ef;
  text-decoration: none;
  transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  cursor: pointer;
}

.crumb-pill:hover {
  background: #1a3f8f;
  color: #fff;
  border-color: #1a3f8f;
}

.crumb-pill.active {
  background: #1faa8b;
  color: #fff;
  border-color: #1faa8b;
  font-weight: 600;
  cursor: default;
}

.crumb-separator {
  color: #9eb3d8;
  font-size: 10px;
  display: flex;
  align-items: center;
}

/* ── Right Block ── */
.breadcrumb-right {
  display: flex;
  align-items: center;
}

.fiscal-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fff;
  color: #1a3f8f;
  font-size: 12px;
  font-weight: 600;
  padding: 5px 14px;
  border-radius: 20px;
  border: 1px solid #c5d4ef;
}

.fiscal-badge i {
  color: #1faa8b;
  font-size: 13px;
}

/* ── Responsive ── */
@media (max-width: 576px) {
  .breadcrumb-right { display: none; }
  .breadcrumb-bar { padding: 10px 16px; }
}
</file>

<file path="src/app/layout/breadcrumbs/breadcrumbs.component.html">
<div class="breadcrumb-bar">
  <div class="breadcrumb-left">

    <div class="page-title-row">
      <div class="page-icon">
        <i class="bi bi-grid-fill"></i>
      </div>
      <h5 class="page-title">{{ pageTitle }}</h5>
    </div>

    <div class="breadcrumb-pills">
      <ng-container *ngFor="let crumb of breadcrumbs; let last = last">

        <a
          *ngIf="!last"
          [routerLink]="crumb.url"
          class="crumb-pill"
        >
          <i class="bi bi-house-fill" *ngIf="crumb.label === 'Home'"></i>
          <span>{{ crumb.label }}</span>
        </a>

        <span *ngIf="!last" class="crumb-separator">
          <i class="bi bi-chevron-right"></i>
        </span>

        <span *ngIf="last" class="crumb-pill active">
          {{ crumb.label }}
        </span>

      </ng-container>
    </div>

  </div>

  <div class="breadcrumb-right">
    <span class="fiscal-badge">
      <i class="bi bi-calendar3"></i>
      FY 2025–2026
    </span>
  </div>
</div>
</file>


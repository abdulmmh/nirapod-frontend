  cursor: pointer;
}
.form-textarea {
  resize: vertical;
  min-height: 70px;
  padding-top: 10px;
}
.auto-field {
  background: #f0f4f8 !important;
  color: #555 !important;
  cursor: not-allowed;
  border-color: #e0e8f0 !important;
}

/* ── Calc Summary ── */
.calc-summary {
  margin-top: 16px;
  border: 1.5px solid #ffcccc;
  border-radius: 12px;
  overflow: hidden;
}
.cs-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 18px;
}
.cs-label {
  font-size: 13px;
  color: #666;
  font-weight: 500;
}
.cs-label.bold {
  font-weight: 700;
  color: #1a2340;
}
.cs-value {
  font-size: 14px;
  font-weight: 700;
  color: #1a2340;
}
.cs-value.duty {
  color: #e74c3c;
}
.cs-value.vat {
  color: #f59e0b;
}
.cs-value.total {
  font-size: 20px;
  font-weight: 800;
  color: #e74c3c;
}
.cs-divider {
  height: 1px;
  background: #ffcccc;
}
.total-row {
  background: #fff0f0;
  padding: 12px 18px;
}

.form-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  padding: 20px 28px;
  background: #f8fafc;
  border-top: 1px solid #f0f4f8;
  flex-wrap: wrap;
}
.btn-cancel {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fff;
  border: 1.5px solid #e0e8f0;
  color: #666;
  padding: 9px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}
.btn-cancel:hover {
  background: #f5f7fb;
}
.btn-reset {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fef3e2;
  border: 1.5px solid #fde8c0;
  color: #f59e0b;
  padding: 9px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}
.btn-reset:hover {
  background: #fde8c0;
}
.btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  border: none;
  padding: 10px 28px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition:
    box-shadow 0.2s,
    transform 0.2s;
}
.btn-submit:hover:not(:disabled) {
  box-shadow: 0 4px 14px rgba(231, 76, 60, 0.35);
  transform: translateY(-1px);
}
.btn-submit:disabled,
.btn-cancel:disabled,
.btn-reset:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}
@media (max-width: 768px) {
  .form-section {
    padding: 18px 16px;
  }
  .section-divider {
    margin: 0 16px;
  }
  .form-grid {
    grid-template-columns: 1fr;
  }
  .form-actions {
    padding: 16px;
    justify-content: stretch;
  }
  .btn-cancel,
  .btn-reset,
  .btn-submit {
    flex: 1;
    justify-content: center;
  }
}
@media (max-width: 480px) {
  .form-actions {
    flex-direction: column;
  }
  .btn-cancel,
  .btn-reset,
  .btn-submit {
    width: 100%;
  }
}

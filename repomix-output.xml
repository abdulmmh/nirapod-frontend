<file path="src/app/features/tin-management/pages/tin-create/tin-create.component.css">
.alert-success {
  background: #e6f7f3;
  border: 1px solid #b2dfdb;
  border-radius: 10px;
  padding: 12px 18px;
  color: #1faa8b;
  font-weight: 600;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}
.alert-error {
  background: #fff0f0;
  border: 1px solid #fcc;
  border-radius: 10px;
  padding: 12px 18px;
  color: #e74c3c;
  font-weight: 600;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}
.btn-back {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: #fff;
  border: 1px solid #b2e4f0;
  color: #0891b2;
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-back:hover {
  background: #e0f2f9;
}
.form-card {
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  overflow: hidden;
}
.form-section {
  padding: 24px 28px;
}
.section-header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}
.section-icon {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, #0891b2, #06b6d4);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 17px;
  flex-shrink: 0;
}
.section-icon.teal {
  background: linear-gradient(135deg, #1faa8b, #17c69a);
}
.section-icon.orange {
  background: linear-gradient(135deg, #f59e0b, #f97316);
}
.section-icon.purple {
  background: linear-gradient(135deg, #7c3aed, #a855f7);
}
.section-title {
  margin: 0;
  font-size: 14px;
  font-weight: 700;
  color: #1a2340;
}
.section-sub {
  font-size: 12px;
  color: #999;
}
.section-divider {
  height: 1px;
  background: #f0f4f8;
  margin: 0 28px;
}
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.form-group.full-width {
  grid-column: 1/-1;
}
.form-label {
  font-size: 13px;
  font-weight: 600;
  color: #444;
}
.form-label.required::after {
  content: " *";
  color: #e74c3c;
}
.input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}
.input-icon {
  position: absolute;
  left: 12px;
  color: #aaa;
  font-size: 14px;
  pointer-events: none;
  z-index: 1;
}
.textarea-icon {
  top: 12px;
  align-self: flex-start;
}
.form-input {
  width: 100%;
  padding: 10px 14px 10px 36px;
  border: 1.5px solid #e0e8f0;
  border-radius: 9px;
  font-size: 13.5px;
  color: #333;
  background: #fafbfc;
  outline: none;
  transition:
    border-color 0.2s,
    box-shadow 0.2s;
  font-family: inherit;
}
.form-input:focus {
  border-color: #0891b2;
  box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.08);
  background: #fff;
}
.form-input:disabled {
  background: #f5f5f5;
  cursor: not-allowed;
}
.form-select {
  appearance: none;
  cursor: pointer;
}
.form-textarea {
  resize: vertical;
  min-height: 70px;
  padding-top: 10px;
}
.form-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  padding: 20px 28px;
  background: #f8fafc;
  border-top: 1px solid #f0f4f8;
  flex-wrap: wrap;
}
.btn-cancel {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fff;
  border: 1.5px solid #e0e8f0;
  color: #666;
  padding: 9px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}
.btn-cancel:hover {
  background: #f5f7fb;
}
.btn-reset {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #fef3e2;
  border: 1.5px solid #fde8c0;
  color: #f59e0b;
  padding: 9px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}
.btn-reset:hover {
  background: #fde8c0;
}
.btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #0891b2, #06b6d4);
  color: #fff;
  border: none;
  padding: 10px 28px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition:
    box-shadow 0.2s,
    transform 0.2s;
}
.btn-submit:hover:not(:disabled) {
  box-shadow: 0 4px 14px rgba(8, 145, 178, 0.35);
  transform: translateY(-1px);
}
.btn-submit:disabled,
.btn-cancel:disabled,
.btn-reset:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}
@media (max-width: 768px) {
  .form-section {
    padding: 18px 16px;
  }
  .section-divider {
    margin: 0 16px;
  }
  .form-grid {
    grid-template-columns: 1fr;
  }
  .form-actions {
    padding: 16px;
    justify-content: stretch;
  }
  .btn-cancel,
  .btn-reset,
  .btn-submit {
    flex: 1;
    justify-content: center;
  }
}
@media (max-width: 480px) {
  .form-actions {
    flex-direction: column;
  }
  .btn-cancel,
  .btn-reset,
  .btn-submit {
    width: 100%;
  }
}

/* ── Taxpayer Search ── */
.section-icon.search-icon {
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
}
.search-row {
  display: flex;
  gap: 10px;
  align-items: center;
}
.search-input-wrap {
  flex: 1;
}
.btn-search {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: #fff;
  border: none;
  padding: 10px 22px;
  border-radius: 9px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.2s;
}
.btn-search:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Search Results */
.search-results {
  margin-top: 8px;
  border: 1.5px solid #e0e8f0;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(0,0,0,0.07);
}
.result-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  cursor: pointer;
  transition: background 0.15s;
  border-bottom: 1px solid #f0f4f8;
}
.result-item:last-child { border-bottom: none; }
.result-item:hover { background: #f0f4ff; }
.result-avatar {
  width: 36px;
  height: 36px;
  background: #ede9fe;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7c3aed;
  font-size: 16px;
  flex-shrink: 0;
}
.result-info { flex: 1; }
.result-name { font-size: 13.5px; font-weight: 600; color: #1a2340; display: block; }
.result-meta { font-size: 12px; color: #888; display: block; margin-top: 2px; }
.result-badge {
  font-size: 11px;
  font-weight: 600;
  background: #ede9fe;
  color: #7c3aed;
  padding: 3px 10px;
  border-radius: 20px;
}

/* No result note */
.no-result-note {
  margin-top: 10px;
  padding: 10px 14px;
  background: #fff8e1;
  border: 1px solid #ffe082;
  border-radius: 8px;
  font-size: 12.5px;
  color: #b45309;
  display: flex;
  align-items: center;
  gap: 7px;
}

/* Selected Taxpayer Card */
.selected-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12px;
  padding: 12px 16px;
  background: #f0fdf4;
  border: 1.5px solid #86efac;
  border-radius: 10px;
}
.selected-card-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.selected-avatar {
  width: 38px;
  height: 38px;
  background: #dcfce7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #16a34a;
  font-size: 18px;
  flex-shrink: 0;
}
.selected-name {
  margin: 0;
  font-size: 13.5px;
  font-weight: 700;
  color: #14532d;
}
.selected-meta {
  margin: 2px 0 0;
  font-size: 12px;
  color: #16a34a;
}
.autofill-tag {
  font-size: 11.5px;
  font-weight: 700;
  background: #dcfce7;
  color: #16a34a;
  padding: 4px 12px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  gap: 5px;
}

/* Locked fields */
.input-wrap.locked .form-input {
  background: #f0fdf4;
  border-color: #86efac;
  color: #15803d;
}
.lock-icon {
  position: absolute;
  right: 12px;
  color: #16a34a;
  font-size: 12px;
}
.textarea-lock {
  top: 12px;
  align-self: flex-start;
}

/* Clear button inside input */
.clear-btn {
  position: absolute;
  right: 12px;
  background: none;
  border: none;
  color: #aaa;
  cursor: pointer;
  font-size: 13px;
  padding: 2px;
  display: flex;
  align-items: center;
}
.clear-btn:hover { color: #e74c3c; }

@media (max-width: 768px) {
  .search-row { flex-direction: column; }
  .btn-search { width: 100%; justify-content: center; }
  .selected-card { flex-direction: column; align-items: flex-start; gap: 8px; }
}
</file>


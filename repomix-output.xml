<file path="src/app/shared/toast/toast.component.css">
.toast-container {
  position: fixed;
  top: 84px;
  right: 20px;
  z-index: 99999;
  display: flex;
  flex-direction: column;
  gap: 12px;
  pointer-events: none;
  max-width: calc(100vw - 24px);
}

.toast {
  position: relative;
  overflow: hidden;
  pointer-events: all;

  display: flex;
  align-items: flex-start;
  gap: 12px;

  width: 360px;
  max-width: 100%;
  padding: 14px 16px;

  border-radius: 14px;
  border: 1px solid #e8edf5;
  border-left: 4px solid;
  background: rgba(255, 255, 255, 0.98);
  box-shadow:
    0 10px 30px rgba(15, 23, 42, 0.10),
    0 2px 8px rgba(15, 23, 42, 0.06);

  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);

  animation: toast-slide-in 0.32s ease;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.toast:hover {
  transform: translateY(-1px);
  box-shadow:
    0 14px 34px rgba(15, 23, 42, 0.13),
    0 4px 10px rgba(15, 23, 42, 0.08);
}

@keyframes toast-slide-in {
  from {
    opacity: 0;
    transform: translateX(48px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

.toast-success {
  border-left-color: #16a34a;
}

.toast-error {
  border-left-color: #dc2626;
}

.toast-warning {
  border-left-color: #d97706;
}

.toast-info {
  border-left-color: #2563eb;
}

.toast-icon {
  width: 38px;
  height: 38px;
  min-width: 38px;
  border-radius: 50%;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 15px;
  flex-shrink: 0;
  margin-top: 1px;

  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.45);
}

.toast-success .toast-icon {
  background: linear-gradient(135deg, #e8f8ee, #d8f1e1);
  color: #15803d;
}

.toast-error .toast-icon {
  background: linear-gradient(135deg, #fdecec, #fbd5d5);
  color: #b91c1c;
}

.toast-warning .toast-icon {
  background: linear-gradient(135deg, #fff4e5, #fde7c2);
  color: #b45309;
}

.toast-info .toast-icon {
  background: linear-gradient(135deg, #eaf2ff, #dbeafe);
  color: #1d4ed8;
}

.toast-body {
  flex: 1;
  min-width: 0;
  padding-right: 6px;
}

.toast-title {
  margin: 0 0 4px;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.25;
  color: #111827;
  letter-spacing: 0.1px;
}

.toast-msg {
  margin: 0;
  font-size: 12.5px;
  font-weight: 500;
  line-height: 1.5;
  color: #6b7280;
  word-break: break-word;
}

.toast-close {
  width: 28px;
  height: 28px;
  min-width: 28px;

  display: flex;
  align-items: center;
  justify-content: center;

  margin-top: -2px;
  border: none;
  border-radius: 8px;
  background: transparent;
  color: #94a3b8;
  cursor: pointer;
  flex-shrink: 0;

  transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.toast-close:hover {
  background: #f1f5f9;
  color: #334155;
}

.toast-close:active {
  transform: scale(0.96);
}

.toast-progress {
  position: absolute;
  left: 0;
  bottom: 0;
  height: 3px;
  border-radius: 0 0 0 14px;
  animation: toast-progress linear forwards;
  opacity: 0.95;
}

.toast-progress-success {
  background: linear-gradient(90deg, #22c55e, #16a34a);
}

.toast-progress-error {
  background: linear-gradient(90deg, #ef4444, #dc2626);
}

.toast-progress-warning {
  background: linear-gradient(90deg, #f59e0b, #d97706);
}

.toast-progress-info {
  background: linear-gradient(90deg, #3b82f6, #2563eb);
}

@keyframes toast-progress {
  from {
    width: 100%;
  }
  to {
    width: 0%;
  }
}

@media (max-width: 768px) {
  .toast-container {
    top: 76px;
    right: 14px;
    left: 14px;
  }

  .toast {
    width: 100%;
  }
}

@media (max-width: 480px) {
  .toast-container {
    top: 70px;
    right: 10px;
    left: 10px;
    gap: 10px;
  }

  .toast {
    padding: 13px 14px;
    border-radius: 12px;
  }

  .toast-title {
    font-size: 13px;
  }

  .toast-msg {
    font-size: 12px;
  }

  .toast-icon {
    width: 34px;
    height: 34px;
    min-width: 34px;
    font-size: 14px;
  }
}
